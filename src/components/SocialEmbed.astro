---
interface SocialEmbedNode {
  platform?: "instagram" | "tiktok" | "youtube" | string;
  url?: string;
  caption?: string;
}

const { node } = Astro.props as { node: SocialEmbedNode };
const platform = node?.platform || "instagram";
const url = node?.url || "";
const caption = node?.caption;

const getYouTubeEmbedUrl = (sourceUrl: string) => {
  try {
    const parsed = new URL(sourceUrl);
    const videoId =
      parsed.hostname.includes("youtu.be")
        ? parsed.pathname.split("/").filter(Boolean)[0]
        : parsed.searchParams.get("v") ||
          parsed.pathname.match(/\/(?:shorts|embed)\/([^/?]+)/)?.[1];
    return videoId ? `https://www.youtube.com/embed/${videoId}` : undefined;
  } catch {
    return undefined;
  }
};

const getInstagramEmbedUrl = (sourceUrl: string) => {
  try {
    const parsed = new URL(sourceUrl);
    const match = parsed.pathname.match(/\/(p|reel|tv)\/([^/?]+)/);
    if (!match) return undefined;
    return `https://www.instagram.com/${match[1]}/${match[2]}/embed/captioned/`;
  } catch {
    return undefined;
  }
};

const getTikTokVideoId = (sourceUrl: string) => {
  try {
    return new URL(sourceUrl).pathname.match(/\/video\/(\d+)/)?.[1] || "";
  } catch {
    return "";
  }
};

const instagramEmbedUrl =
  platform === "instagram" ? getInstagramEmbedUrl(url) : undefined;
const youtubeEmbedUrl = platform === "youtube" ? getYouTubeEmbedUrl(url) : undefined;
const tiktokVideoId = platform === "tiktok" ? getTikTokVideoId(url) : "";
---

{url && (
  <figure class={`social-embed social-embed--${platform}`}>
    {platform === "instagram" && instagramEmbedUrl && (
      <iframe
        class="social-embed-frame social-embed-frame--instagram"
        src={instagramEmbedUrl}
        title={caption || "Embedded Instagram post"}
        loading="lazy"
        allow="autoplay; clipboard-write; encrypted-media; picture-in-picture; web-share"
      ></iframe>
    )}

    {platform === "instagram" && !instagramEmbedUrl && (
      <a class="social-embed-fallback" href={url} target="_blank" rel="noopener noreferrer">
        View this post on Instagram
      </a>
    )}

    {platform === "tiktok" && (
      <blockquote class="tiktok-embed" cite={url} data-video-id={tiktokVideoId}>
        <a href={url} target="_blank" rel="noopener noreferrer">
          View this post on TikTok
        </a>
      </blockquote>
    )}

    {platform === "youtube" && youtubeEmbedUrl && (
      <iframe
        src={youtubeEmbedUrl}
        title={caption || "Embedded YouTube video"}
        loading="lazy"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
        allowfullscreen
      ></iframe>
    )}

    {platform === "youtube" && !youtubeEmbedUrl && (
      <a class="social-embed-fallback" href={url} target="_blank" rel="noopener noreferrer">
        Watch the source video
      </a>
    )}

    <figcaption>
      {caption && <span>{caption}</span>}
      <a href={url} target="_blank" rel="noopener noreferrer">
        Open source post
      </a>
    </figcaption>
  </figure>
)}

{url && platform === "tiktok" && <script async src="https://www.tiktok.com/embed.js"></script>}

<style>
  .social-embed {
    display: grid;
    justify-items: center;
    gap: 0.7rem;
    margin: 2rem 0;
  }

  .social-embed :global(.tiktok-embed) {
    width: min(100%, 540px) !important;
    min-width: 0 !important;
    margin: 0 auto !important;
  }

  .social-embed iframe {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    border: 0;
    background: #111111;
  }

  .social-embed-frame--instagram {
    width: min(100%, 540px);
    height: min(720px, 82vh);
    border: 1px solid rgba(5, 5, 5, 0.14);
    background: #ffffff;
  }

  .social-embed-fallback {
    display: inline-flex;
    justify-content: center;
    border: 1px solid rgba(5, 5, 5, 0.16);
    color: #111111;
    padding: 0.9rem 1rem;
    text-decoration: none;
  }

  .social-embed figcaption {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem 0.65rem;
    width: min(100%, 540px);
    margin: 0;
    color: rgba(5, 5, 5, 0.58);
    font: 700 0.74rem/1.45 var(--font-body);
  }

  .social-embed figcaption a {
    color: rgba(5, 5, 5, 0.72);
    text-decoration: underline;
    text-underline-offset: 0.18em;
  }
</style>
