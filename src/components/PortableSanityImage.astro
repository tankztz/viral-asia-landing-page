---
import imageUrlBuilder from "@sanity/image-url";
import type { SanityImageSource } from "@sanity/image-url/lib/types/types";
import { sanityClient } from "sanity:client";

interface SanityImageNode {
  asset?: SanityImageSource;
  alt?: string;
  caption?: string;
  sourceLabel?: string;
  sourceUrl?: string;
}

const { node } = Astro.props as { node: SanityImageNode };
const { projectId, dataset } = sanityClient.config();
const imageUrl =
  node?.asset && projectId && dataset
    ? imageUrlBuilder({ projectId, dataset })
        .image(node.asset)
        .width(1400)
        .fit("max")
        .auto("format")
        .url()
    : undefined;
---

{imageUrl && (
  <figure class="portable-image">
    <img src={imageUrl} alt={node.alt || ""} loading="lazy" />
    {(node.caption || node.sourceLabel) && (
      <figcaption>
        {node.caption && <span>{node.caption}</span>}
        {node.sourceLabel && node.sourceUrl ? (
          <a href={node.sourceUrl} target="_blank" rel="noopener noreferrer">
            {node.sourceLabel}
          </a>
        ) : (
          node.sourceLabel && <span>{node.sourceLabel}</span>
        )}
      </figcaption>
    )}
  </figure>
)}

<style>
  .portable-image {
    margin: 2rem 0;
  }

  .portable-image img {
    display: block;
    width: 100%;
    height: auto;
    border: 1px solid rgba(5, 5, 5, 0.08);
    border-radius: 0;
    background: #111;
    object-fit: contain;
  }

  .portable-image figcaption {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem 0.65rem;
    margin-top: 0.55rem;
    color: rgba(5, 5, 5, 0.55);
    font: 700 0.74rem/1.45 var(--font-body);
  }

  .portable-image figcaption a {
    color: rgba(5, 5, 5, 0.72);
    text-decoration: underline;
    text-underline-offset: 0.18em;
  }
</style>
