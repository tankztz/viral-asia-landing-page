---
import { navItems, whatsappHref } from "../data/viralSite";

interface Props {
  title: string;
  subtitle?: string;
  showBackButton?: boolean;
}

const { title, subtitle, showBackButton = false } = Astro.props;
---

<header class="blog-masthead">
  <div class="masthead-inner">
    <a class="brand" href="/" aria-label="Viral Asia home">
      <img src="/images/viral-asia-logo-transparent.png" alt="Viral Asia" />
    </a>

    <nav aria-label="Main navigation">
      <a href="/" aria-current={showBackButton ? undefined : "page"}>Main page</a>
      {navItems.slice(1, 4).map(([label, href]) => <a href={href}>{label}</a>)}
    </nav>

    <a class="masthead-cta" href={whatsappHref}>Enquire now</a>
  </div>

  <div class="masthead-title">
    {
      showBackButton && (
        <a class="back-link" href="/" aria-label="Back to main page">
          <span aria-hidden="true">←</span>
          Back to main page
        </a>
      )
    }
    <p>Viral Asia</p>
    <h1>{title}</h1>
    {subtitle && <span>{subtitle}</span>}
  </div>
</header>

<style>
  .blog-masthead {
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid rgba(255, 255, 255, 0.14);
    background:
      radial-gradient(
        circle at 78% 12%,
        rgba(255, 225, 0, 0.2),
        transparent 20rem
      ),
      radial-gradient(
        circle at 12% 2%,
        rgba(233, 21, 21, 0.28),
        transparent 24rem
      ),
      #050505;
    color: white;
  }

  .blog-masthead::after {
    position: absolute;
    inset: auto 0 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, #e91515, #ffe100, transparent);
    content: "";
  }

  .masthead-inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 160px 1fr auto;
    align-items: center;
    gap: 1rem;
    max-width: 1180px;
    margin: 0 auto;
    padding: 1rem 1.25rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
  }

  .brand img {
    display: block;
    width: 7.3rem;
    max-width: 100%;
    height: auto;
  }

  nav {
    display: flex;
    justify-content: center;
    gap: clamp(0.9rem, 2.4vw, 2rem);
  }

  nav a,
  .masthead-cta,
  .back-link {
    font: 900 0.74rem/1 var(--font-body);
    letter-spacing: 0.02em;
    text-decoration: none;
    text-transform: uppercase;
    white-space: nowrap;
  }

  nav a {
    color: rgba(255, 255, 255, 0.76);
    transition:
      color 180ms ease,
      transform 180ms ease;
  }

  nav a:hover,
  nav a[aria-current="page"] {
    color: #ffe100;
    transform: translateY(-1px);
  }

  .masthead-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.45rem;
    border: 2px solid rgba(255, 255, 255, 0.14);
    border-radius: 4px;
    background: #e91515;
    box-shadow: 0 0.38rem 0 rgba(0, 0, 0, 0.48);
    color: white;
    padding: 0.72rem 1rem;
    transition:
      filter 180ms ease,
      transform 180ms ease;
  }

  .masthead-cta:hover {
    filter: brightness(1.08);
    transform: translateY(-1px);
  }

  .masthead-cta:active {
    transform: translateY(1px);
  }

  .masthead-title {
    position: relative;
    z-index: 1;
    max-width: 1180px;
    margin: 0 auto;
    padding: clamp(2rem, 6vw, 4.5rem) 1.25rem clamp(2.6rem, 7vw, 5.5rem);
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.35rem;
    color: rgba(255, 255, 255, 0.78);
  }

  .back-link:hover {
    color: #ffe100;
  }

  .masthead-title p {
    margin: 0 0 0.7rem;
    color: #ffe100;
    font: 900 0.76rem/1 var(--font-body);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .masthead-title h1 {
    max-width: 920px;
    margin: 0;
    color: white;
    font:
      900 clamp(2.8rem, 9vw, 7.2rem) / 0.9 var(--font-display);
    letter-spacing: 0;
    text-transform: uppercase;
    text-wrap: balance;
  }

  .masthead-title span {
    display: block;
    max-width: 56rem;
    margin-top: 1rem;
    color: rgba(255, 255, 255, 0.76);
    font: 600 clamp(1rem, 2vw, 1.18rem) / 1.5 var(--font-body);
  }

  @media (max-width: 840px) {
    .masthead-inner {
      grid-template-columns: 1fr auto;
    }

    nav {
      grid-column: 1 / -1;
      justify-content: flex-start;
      overflow-x: auto;
      padding-bottom: 0.2rem;
      scrollbar-width: none;
    }

    nav::-webkit-scrollbar {
      display: none;
    }
  }

  @media (max-width: 560px) {
    .masthead-inner {
      grid-template-columns: 1fr;
      align-items: start;
    }

    .masthead-cta {
      width: max-content;
    }
  }
</style>
