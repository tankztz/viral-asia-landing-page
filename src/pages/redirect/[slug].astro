---
import Layout from "../../layouts/Layout.astro";
import viralPosts from "../../data/viralPosts.json";

export function getStaticPaths() {
  return viralPosts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
---

<Layout title={`Redirecting - ${post.title}`}>
  <main class="redirect-page">
    <section class="redirect-card" data-target={post.redirectUrl}>
      <p class="eyebrow">Third-party redirect</p>
      <h1>You are redirecting to a third-party site</h1>
      <p class="summary">
        You are viewing a Viral Asia viral post: <strong>{post.title}</strong>.
      </p>
      <p class="note">
        Note: the view count shown on our site is a combined view estimate
        across Instagram, Facebook, TikTok and Xiaohongshu. The third-party page
        may show only that platform's own count.
      </p>
      <div class="countdown" aria-live="polite">
        Redirecting in <strong id="seconds">5</strong>
      </div>
      <a class="cta" href={post.redirectUrl}>Open now</a>
    </section>
  </main>
</Layout>

<script>
  const card = document.querySelector(".redirect-card");
  const secondsNode = document.querySelector("#seconds");
  const target = card?.getAttribute("data-target");
  let seconds = 5;

  const timer = window.setInterval(() => {
    seconds -= 1;
    if (secondsNode) secondsNode.textContent = String(seconds);
    if (seconds <= 0) {
      window.clearInterval(timer);
      if (target) window.location.href = target;
    }
  }, 1000);
</script>

<style>
  :global(body) {
    background: #050505;
  }

  .redirect-page {
    display: grid;
    min-height: 100dvh;
    place-items: center;
    padding: 1.5rem;
    background:
      radial-gradient(
        circle at 50% 0,
        rgba(233, 21, 21, 0.24),
        transparent 28rem
      ),
      #050505;
    color: white;
  }

  .redirect-card {
    width: min(46rem, 100%);
    border: 1px solid rgba(255, 255, 255, 0.18);
    background: linear-gradient(135deg, #1b1b1b, #080808);
    padding: clamp(1.25rem, 5vw, 3rem);
  }

  .eyebrow {
    margin: 0 0 0.85rem;
    color: #ffe100;
    font-size: 0.78rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    font:
      900 clamp(2.4rem, 8vw, 5rem) / 0.9 var(--font-display),
      sans-serif;
    text-transform: uppercase;
  }

  .summary,
  .note {
    max-width: 40rem;
    margin: 1rem 0 0;
    color: #f1f1f1;
    font-size: 1rem;
    line-height: 1.45;
  }

  .note {
    color: #cfcfcf;
  }

  .countdown {
    margin-top: 1.4rem;
    color: #ffe100;
    font-size: 1.2rem;
    font-weight: 900;
  }

  .cta {
    display: inline-flex;
    margin-top: 1.3rem;
    border-radius: 4px;
    background: #e91515;
    box-shadow: 0 0.45rem 0 rgba(0, 0, 0, 0.5);
    color: white;
    font-size: 0.85rem;
    font-weight: 900;
    padding: 0.75rem 1.2rem;
    text-decoration: none;
    text-transform: uppercase;
  }
</style>
