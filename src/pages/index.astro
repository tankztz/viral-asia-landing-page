  @media (any-pointer: coarse) {
    .hero-cta-wrap:hover .hero-cta-tip {
      opacity: 0;
      transform: translate(-50%, 0.45rem) scale(0.98);
    }

    .hero-cta-wrap:focus-within .hero-cta-tip {
      opacity: 1;
      transform: translate(-50%, 0) scale(1);
    }
  }

  @media (max-width: 560px) and (any-pointer: coarse) {
    .hero-cta-wrap:hover .hero-cta-tip {
      transform: translateY(0.45rem) scale(0.98);
    }

    .hero-cta-wrap:focus-within .hero-cta-tip {
      transform: translateY(0) scale(1);
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  const reduceMotion = window.matchMedia(
    "(prefers-reduced-motion: reduce)",
  ).matches;

  const menuButton =
    document.querySelector<HTMLButtonElement>("[data-menu-button]");
  const mobileMenu = document.querySelector<HTMLElement>("[data-mobile-menu]");
  const mobilePanel =
    mobileMenu?.querySelector<HTMLElement>(".mobile-menu-panel");
  const mobileLinks = mobileMenu
    ? gsap.utils.toArray<HTMLAnchorElement>(".mobile-menu-panel a")
    : [];
  let menuOpen = false;

  const menuTl =
    menuButton && mobileMenu && mobilePanel
      ? gsap
          .timeline({
            paused: true,
            defaults: { ease: "power3.out" },
          })
          .to(mobileMenu, { autoAlpha: 1, duration: 0.18 }, 0)
          .fromTo(
            mobilePanel,
            { y: -16, scale: 0.98 },
            { y: 0, scale: 1, duration: 0.36 },
            0,
          )
          .fromTo(
            mobileLinks,
            { y: 14, opacity: 0 },
            { y: 0, opacity: 1, duration: 0.28, stagger: 0.045 },
            0.08,
          )
      : null;

  function setMenu(open: boolean) {
    if (!menuButton || !mobileMenu || !menuTl) return;

    menuOpen = open;
    menuButton.setAttribute("aria-expanded", String(open));
    mobileMenu.setAttribute("aria-hidden", String(!open));
    mobileMenu.style.pointerEvents = open ? "auto" : "none";
    document.documentElement.classList.toggle("menu-open", open);

    if (reduceMotion) {
      menuTl.progress(open ? 1 : 0).pause();
      return;
    }

    open ? menuTl.play() : menuTl.reverse();
  }

  const handleMenuClick = () => setMenu(!menuOpen);
  const handleMenuBackdrop = (event: MouseEvent) => {
    if (event.target === mobileMenu) setMenu(false);
  };
  const handleMenuKeydown = (event: KeyboardEvent) => {
    if (event.key === "Escape") setMenu(false);
  };
  const handleMenuLinkClick = () => setMenu(false);

  menuButton?.addEventListener("click", handleMenuClick);
  mobileMenu?.addEventListener("click", handleMenuBackdrop);
  document.addEventListener("keydown", handleMenuKeydown);
  mobileLinks.forEach((link) =>
    link.addEventListener("click", handleMenuLinkClick),
  );

  if (!reduceMotion) {
    gsap.registerPlugin(ScrollTrigger);

    const ctx = gsap.context(() => {
      gsap.from(".hero-word", {
        yPercent: 110,
        opacity: 0,
        duration: 1.05,
        stagger: 0.08,
        ease: "power4.out",
      });

      gsap.to(".phone-card-main", {
        y: -28,
        rotate: -2,
        ease: "none",
        scrollTrigger: {
          trigger: ".hero",
          start: "top top",
          end: "bottom top",
          scrub: true,
        },
      });

      gsap.to(".phone-card-offset", {
        y: 36,
        rotate: 2,
        ease: "none",
        scrollTrigger: {
          trigger: ".hero",
          start: "top top",
          end: "bottom top",
          scrub: true,
        },
      });

      gsap.utils.toArray<HTMLElement>(".reveal").forEach((element) => {
        gsap.from(element, {
          y: 42,
          opacity: 0,
          duration: 0.9,
          ease: "power3.out",
          scrollTrigger: {
            trigger: element,
            start: "top 82%",
            once: true,
          },
        });
      });

      const quoteLines = gsap.utils.toArray<HTMLElement>(".quote-line");
      gsap
        .timeline({
          scrollTrigger: {
            trigger: ".intro",
            start: "top 70%",
            once: true,
          },
          defaults: { ease: "power4.out" },
        })
        .from(
          quoteLines,
          {
            yPercent: 32,
            opacity: 0,
            duration: 0.72,
            stagger: 0.09,
          },
          0,
        )
        .from(
          ".quote-value",
          {
            letterSpacing: "-0.16em",
            duration: 1,
          },
          0.22,
        )
        .from(
          ".quote-capability strong",
          {
            scale: 0.72,
            opacity: 0,
            duration: 0.95,
            ease: "back.out(1.7)",
          },
          0.18,
        )
        .from(
          ".intro footer",
          {
            y: 16,
            opacity: 0,
            duration: 0.52,
          },
          0.62,
        );
    });

    document.addEventListener("astro:before-swap", () => ctx.revert(), {
      once: true,
    });
  }

  document.addEventListener(
    "astro:before-swap",
    () => {
      setMenu(false);
      menuButton?.removeEventListener("click", handleMenuClick);
      mobileMenu?.removeEventListener("click", handleMenuBackdrop);
      document.removeEventListener("keydown", handleMenuKeydown);
      mobileLinks.forEach((link) =>
        link.removeEventListener("click", handleMenuLinkClick),
      );
      menuTl?.kill();
    },
    { once: true },
  );
</script>
