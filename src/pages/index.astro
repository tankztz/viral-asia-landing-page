---

<Layout title="Viral Asia - TikTok Affiliate Marketing Partner">
  <main class="va-site" data-va-root>
    <nav class="va-nav" aria-label="Primary navigation">
      <a class="va-brand" href="/" aria-label="Viral Asia home">
        <img src="/company/ViralAsia.png" alt="Viral Asia" />
        <span>Viral Asia</span>
      </a>
      <div class="va-nav-links">
        <a href="#work">Work</a>
        <a href="#services">Services</a>
        <a href="#proof">Proof</a>
        <a href="/blog">Blog</a>
      </div>
      <div class="va-nav-actions">
        <a class="va-button va-button-small va-nav-cta" href={whatsappHref}>
          Enquire Now
        </a>
        <button
          class="nav-menu-button"
          type="button"
          aria-expanded="false"
          aria-controls="mobile-menu"
          data-menu-button
        >
          <span>Menu</span>
          <i aria-hidden="true"></i>
        </button>
      </div>
    </nav>

    <div
      class="mobile-menu"
      id="mobile-menu"
      aria-hidden="true"
      data-mobile-menu
    >
      <div class="mobile-menu-panel">
        <div class="mobile-menu-top">
          <span>Viral Asia</span>
          <span>TikTok affiliate partner</span>
        </div>
        <a href="#work">
          <span class="mobile-link-main">Work</span>
          <span class="mobile-link-note">Campaign proof</span>
        </a>
        <a href="#services">
          <span class="mobile-link-main">Services</span>
          <span class="mobile-link-note">What we do</span>
        </a>
        <a href="#proof">
          <span class="mobile-link-main">Proof</span>
          <span class="mobile-link-note">Results</span>
        </a>
        <a href="/blog">
          <span class="mobile-link-main">Blog</span>
          <span class="mobile-link-note">Writing</span>
        </a>
        <a class="va-button mobile-menu-cta" href={whatsappHref}>
          Enquire Now
        </a>
      </div>
    </div>

    <section class="hero va-section">
      <div class="hero-copy">
        <p class="va-kicker reveal">TikTok Affiliate Partner</p>
        <h1 aria-label="Go viral today">
          <span class="hero-word">Go</span>
          <span class="hero-word hero-word-outline">VIRAL</span>
          <span class="hero-word">Today</span>
        </h1>
        <p class="hero-lede">
          Strategic social content for Singapore brands that need attention to
          turn into demand.
        </p>
        <div class="hero-actions">
          <span class="hero-cta-wrap">
            <a
              class="va-button hero-primary-cta"
              href={whatsappHref}
              aria-describedby="hero-cta-tip"
            >
              Enquire Now
            </a>
            <span class="hero-cta-tip" id="hero-cta-tip" role="tooltip">
              <span class="whatsapp-mark" aria-hidden="true">
                <img
                  src="https://cdn.simpleicons.org/whatsapp/ffffff"
                  alt=""
                  loading="lazy"
                />
              </span>
              <span>
                Get free social media suggestions with our specialist on
                WhatsApp.
              </span>
            </span>
          </span>
          <a class="va-button va-button-secondary" href="#work">See the work</a>
        </div>
      </div>

      <div class="hero-stage reveal" aria-label="Viral Asia visual proof">
        <div class="phone-card phone-card-main">
          <img
            src="/viral-posts/food/26yrfishball.png"
            alt="Food campaign example"
          />
        </div>
        <div class="phone-card phone-card-offset">
          <img
            src="/viral-posts/property/Screenshot_1.png"
            alt="Property campaign example"
          />
        </div>
        <div class="hero-orbit">
          <img src="/images/tiktok-logo.gif" alt="TikTok logo" />
        </div>
      </div>
    </section>

    <section class="va-section intro reveal">
      <blockquote>
        <span class="intro-quote-mark" aria-hidden="true">&ldquo;</span>
        <p class="intro-quote-copy">
          <span class="quote-line quote-context">
            <span>From platforms,</span>
            <span>for businesses:</span>
          </span>
          <span class="quote-line quote-capability">
            we know what drives <strong>engagement</strong>
          </span>
          <span class="quote-line quote-outcome">
            <span class="quote-outcome-lead">and how to</span>
            <span class="quote-value">make your brand stand out</span>
          </span>
          <span class="quote-line quote-method">
            through <strong>strategic TikTok partnerships.</strong>
          </span>
        </p>
        <footer>
          <strong>Toby Cai</strong>
          <span>CEO and Founder of Viralasia</span>
        </footer>
      </blockquote>
    </section>

    <section class="va-section portfolio" id="work">
      <div class="section-title reveal">
        <p class="va-kicker">Our Viral Posts</p>
        <h2>Content built for the Singapore feed.</h2>
        <p>
          Food, things to do, lifestyle, dating, property and bilingual videos
          designed for where attention actually lives.
        </p>
      </div>

      <div class="viral-reel-wall reveal">
        {
          viralRows.map((row) => (
            <article class="viral-row">
              <div class="viral-row-copy">
                <h3>{row.title}</h3>
                <p>{row.body}</p>
              </div>
              <div class="viral-carousel" data-direction={row.direction}>
                <div class="viral-track">
                  {[...row.items, ...row.items].map(([image, count, alt]) => (
                    <figure class="viral-card">
                      <img
                        src={`/viral-posts/${row.title === "Things to do" ? "things_to_do" : row.title.toLowerCase()}/${image}`}
                        alt={alt}
                        loading="lazy"
                      />
                      <figcaption>
                        <span>{count}</span>
                        <small>views</small>
                      </figcaption>
                    </figure>
                  ))}
                </div>
              </div>
            </article>
          ))
        }
      </div>

      <div class="video-strip reveal" aria-label="Horizontal video examples">
        {
          videoLinks.map((video, index) => (
            <a href={video.href} target="_blank" rel="noopener noreferrer">
              <img src={video.image} alt={video.title} loading="lazy" />
              <span>Watch video</span>
              <strong>{video.title}</strong>
            </a>
          ))
        }
      </div>
    </section>

    <section class="va-section accounts reveal">
      <div class="section-title section-title-compact">
        <h2>Our owned channels make the strategy real.</h2>
        <p>
          As a home grown company, we understand the local social media
          landscape and how Singapore audiences actually behave.
        </p>
      </div>
      <div class="account-grid">
        {
          accounts.map((account) => (
            <a
              class="account-card"
              href={account.href}
              target="_blank"
              rel="noopener noreferrer"
            >
              <img src={account.image} alt={account.name} loading="lazy" />
              <span>{account.name}</span>
              <p>{account.description}</p>
            </a>
          ))
        }
      </div>
    </section>

    <section class="va-section services" id="services">
      <div class="section-title reveal">
        <p class="va-kicker">What we offer</p>
        <h2>Five levers. One attention system.</h2>
      </div>
      <div class="service-grid">
        {
          services.map((service, index) => (
            <article class={`service-card service-card-${index + 1} reveal`}>
              <div
                class="service-media"
                style={`background-image: url('${service.image}')`}
              />
              <div>
                <span>{String(index + 1).padStart(2, "0")}</span>
                <h3>{service.title}</h3>
                <p>{service.body}</p>
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <section class="va-section proof" id="proof">
      <div class="section-title reveal">
        <p class="va-kicker">Before and After</p>
        <h2>Proof that attention can move business.</h2>
      </div>
      <div class="result-grid">
        {
          results.map((result) => (
            <article class="result-card reveal">
              <img
                src={result.image}
                alt={`${result.company} result`}
                loading="lazy"
              />
              <strong>{result.metric}</strong>
              <p>{result.label}</p>
              <span>{result.company}</span>
            </article>
          ))
        }
      </div>
    </section>

    <section class="va-section testimonials">
      <div class="testimonial-stack">
        {
          testimonials.map((testimonial) => (
            <article class="testimonial-card reveal">
              <img
                src={testimonial.logo}
                alt={`${testimonial.signature} company logo`}
                loading="lazy"
              />
              <blockquote>{testimonial.quote}</blockquote>
              <p>{testimonial.signature}</p>
              <span>{testimonial.position}</span>
            </article>
          ))
        }
      </div>
    </section>

    <section class="logo-marquee va-section" aria-label="Our Viral Partners">
      <div class="section-title reveal">
        <p class="va-kicker">Our Viral Partners</p>
        <h2>Experience the reliability chosen by industry giants.</h2>
      </div>
      <div class="marquee-track" aria-hidden="true">
        {
          partners.map(([image, name]) => (
            <div class="partner-logo">
              <img src={`/logos/${image}`} alt={name} loading="lazy" />
            </div>
          ))
        }
      </div>
    </section>

    <footer class="va-footer">
      <div>
        <h2>Get in Touch Today</h2>
        <a class="va-button" href={whatsappHref}>Enquire Now</a>
      </div>
      <address>
        <span>11 mosque street #02-01</span>
        <a href="mailto:hello@viralasia.co">hello@viralasia.co</a>
        <a href="tel:+6590906912">(+65) 9090 6912</a>
      </address>
      <p>© 2025 VIRALASIA PTE LTD. ALL RIGHTS RESERVED.</p>
    </footer>
  </main>
</Layout>

<style>
  :global(body) {
    overflow-x: hidden;
  }

  :global(html.menu-open),
  :global(html.menu-open body) {
    overflow: hidden;
  }

  .va-site {
    --bg: #08070b;
    --surface: #121018;
    --surface-2: #1b1724;
    --ink: #f7f5ff;
    --muted: #b9b3c9;
    --line: rgba(247, 245, 255, 0.14);
    --accent: #7452ff;
    --accent-2: #b8a8ff;
    --radius: 28px;
    min-height: 100dvh;
    background:
      radial-gradient(
        circle at 78% 8%,
        rgba(116, 82, 255, 0.3),
        transparent 30rem
      ),
      radial-gradient(
        circle at 10% 22%,
        rgba(255, 255, 255, 0.08),
        transparent 22rem
      ),
      linear-gradient(180deg, #08070b 0%, #110d19 48%, #08070b 100%);
    color: var(--ink);
    touch-action: pan-y pinch-zoom;
    font-family:
      ui-sans-serif,
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      sans-serif;
  }

  .va-site::before {
    content: "";
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    opacity: 0.22;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.06) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.06) 1px, transparent 1px);
    background-size: 80px 80px;
    mask-image: linear-gradient(to bottom, black 0%, transparent 72%);
  }

  .va-site > * {
    position: relative;
    z-index: 1;
  }

  .va-site .va-nav {
    position: sticky;
    top: 0;
    z-index: 20;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 1rem;
    width: min(1180px, calc(100% - 2rem));
    height: 72px;
    margin: 0 auto;
    padding: 0.7rem;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: rgba(8, 7, 11, 0.76);
    backdrop-filter: blur(22px);
    -webkit-backdrop-filter: blur(22px);
  }

  .va-brand,
  .va-nav-links,
  .nav-menu-button,
  .mobile-menu-panel a,
  .va-button,
  .account-card,
  .viral-card,
  .video-strip a {
    touch-action: manipulation;
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      background 180ms ease;
  }

  .va-brand {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    min-width: 0;
    text-decoration: none;
    font-weight: 800;
    letter-spacing: -0.03em;
  }

  .va-brand img {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: #fff;
  }

  .va-nav-links {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.25rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.06);
  }

  .va-nav-links a {
    padding: 0.58rem 0.85rem;
    border-radius: 999px;
    color: var(--muted);
    font-size: 0.9rem;
    text-decoration: none;
  }

  .va-nav-links a:hover {
    background: rgba(255, 255, 255, 0.1);
    color: var(--ink);
  }

  .va-nav-actions {
    display: inline-flex;
    justify-self: end;
    align-items: center;
    gap: 0.5rem;
  }

  .nav-menu-button {
    display: none;
    align-items: center;
    gap: 0.72rem;
    min-height: 38px;
    padding: 0.34rem 0.85rem 0.34rem 0.95rem;
    border: 2px solid rgba(184, 168, 255, 0.86);
    border-radius: 999px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.045), transparent),
      rgba(8, 8, 9, 0.78);
    color: var(--ink);
    font: inherit;
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    cursor: pointer;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.18),
      0 10px 32px rgba(116, 82, 255, 0.22);
  }

  .nav-menu-button i {
    position: relative;
    display: block;
    width: 31px;
    height: 18px;
    background: linear-gradient(var(--accent-2), var(--accent-2)) center / 31px
      2px no-repeat;
  }

  .nav-menu-button i::before,
  .nav-menu-button i::after {
    content: "";
    position: absolute;
    left: 0;
    width: 31px;
    height: 2px;
    border-radius: 999px;
    background: var(--accent-2);
    transition:
      transform 180ms ease,
      background 180ms ease;
  }

  .nav-menu-button i::before {
    top: 1px;
  }

  .nav-menu-button i::after {
    top: 15px;
  }

  .nav-menu-button:hover {
    transform: translateY(-1px);
    border-color: rgba(184, 168, 255, 1);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.08), transparent),
      rgba(24, 18, 42, 0.88);
  }

  .nav-menu-button[aria-expanded="true"] {
    background: var(--accent);
    color: white;
    border-color: rgba(184, 168, 255, 0.95);
  }

  .nav-menu-button[aria-expanded="true"] i {
    background: none;
  }

  .nav-menu-button[aria-expanded="true"] i::before {
    top: 8px;
    transform: rotate(45deg);
    background: white;
  }

  .nav-menu-button[aria-expanded="true"] i::after {
    top: 8px;
    transform: rotate(-45deg);
    background: white;
  }

  .va-site .mobile-menu {
    position: fixed;
    inset: 0;
    z-index: 19;
    display: block;
    visibility: hidden;
    opacity: 0;
    padding: 5.7rem 0.5rem 0;
    background:
      radial-gradient(
        circle at 78% 10%,
        rgba(116, 84, 255, 0.18),
        transparent 32%
      ),
      linear-gradient(180deg, rgba(5, 5, 8, 0.18), rgba(5, 5, 8, 0.7));
    pointer-events: none;
  }

  .va-site .mobile-menu[aria-hidden="false"] {
    pointer-events: auto;
  }

  .mobile-menu-panel {
    box-sizing: border-box;
    display: grid;
    overflow: hidden;
    width: min(calc(100vw - 1rem), 460px);
    margin: 0 auto;
    padding: 0.7rem;
    border: 2px solid rgba(184, 168, 255, 0.7);
    border-radius: 31px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.055), transparent 32%),
      rgba(9, 8, 13, 0.96);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.16),
      0 34px 90px rgba(23, 12, 60, 0.58);
    backdrop-filter: blur(22px);
    -webkit-backdrop-filter: blur(22px);
  }

  .mobile-menu-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.65rem 0.72rem 0.85rem;
    color: var(--accent-2);
    font-size: 0.76rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .mobile-menu-top span:last-child {
    max-width: 13ch;
    color: rgba(184, 168, 255, 0.58);
    font-size: 0.64rem;
    line-height: 1.05;
    text-align: right;
  }

  .mobile-menu-panel a {
    box-sizing: border-box;
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
    min-height: 74px;
    padding: 0.95rem 0.75rem 0.85rem;
    border-top: 1px solid rgba(184, 168, 255, 0.2);
    color: var(--ink);
    letter-spacing: -0.04em;
    text-decoration: none;
    transition:
      color 180ms ease,
      padding 180ms ease,
      background 180ms ease;
  }

  .mobile-menu-panel a:not(.mobile-menu-cta):hover {
    padding-left: 1.05rem;
    background: rgba(116, 82, 255, 0.11);
    color: var(--accent-2);
  }

  .mobile-menu-panel a:not(.mobile-menu-cta):hover .mobile-link-note {
    color: var(--accent-2);
    transform: translateX(-0.15rem);
  }

  .mobile-link-main {
    display: block;
    color: var(--ink);
    font-size: clamp(2rem, 11vw, 3.4rem);
    font-weight: 900;
    line-height: 0.9;
    letter-spacing: -0.08em;
  }

  .mobile-link-note {
    align-self: center;
    color: rgba(184, 168, 255, 0.58);
    font-size: 0.72rem;
    font-weight: 850;
    letter-spacing: 0.04em;
    text-align: right;
    text-transform: uppercase;
    transition:
      color 180ms ease,
      transform 180ms ease;
  }

  .mobile-menu-panel .mobile-menu-cta {
    display: inline-flex;
    grid-template-columns: none;
    align-items: center;
    justify-content: center;
    min-height: 54px;
    width: 100%;
    margin-top: 0.7rem;
    border-color: rgba(184, 168, 255, 0.62);
    background: var(--accent);
    color: white;
    font-size: 1rem;
    box-shadow: none;
  }

  .va-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: fit-content;
    min-height: 52px;
    padding: 0 1.2rem;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 999px;
    background: var(--accent);
    color: white;
    font-weight: 800;
    letter-spacing: -0.02em;
    text-decoration: none;
    white-space: nowrap;
  }

  .va-button:hover {
    transform: translateY(-2px);
    background: #8466ff;
  }

  .va-button:active,
  .account-card:active,
  .nav-menu-button:active,
  .viral-card:active,
  .video-strip a:active {
    transform: translateY(1px) scale(0.99);
  }

  .va-button-small {
    justify-self: end;
    min-height: 44px;
    padding-inline: 1rem;
    font-size: 0.9rem;
  }

  .va-button-secondary {
    background: rgba(255, 255, 255, 0.08);
    color: var(--ink);
  }

  .va-section {
    width: min(1180px, calc(100% - 2rem));
    margin: 0 auto;
    padding: clamp(4rem, 8vw, 8rem) 0;
  }

  .portfolio,
  .services,
  .proof {
    scroll-margin-top: 6rem;
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(320px, 0.95fr);
    align-items: start;
    gap: clamp(2rem, 6vw, 5rem);
    min-height: calc(100dvh - 72px);
    padding-top: clamp(3rem, 6vh, 4.5rem);
    padding-bottom: clamp(3rem, 6vh, 4.5rem);
  }

  .va-kicker {
    margin: 0 0 1rem;
    color: var(--accent-2);
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  h1 {
    display: grid;
    gap: 0.08em;
    margin: 0;
    font-size: clamp(4.2rem, 7.6vw, 6.85rem);
    line-height: 0.86;
    letter-spacing: -0.075em;
    text-transform: uppercase;
  }

  .hero-word {
    display: block;
  }

  .hero-word-outline {
    color: transparent;
    -webkit-text-stroke: clamp(1px, 0.035em, 5px) var(--accent);
  }

  .hero-lede {
    max-width: 34rem;
    margin: 1.8rem 0 0;
    color: var(--muted);
    font-size: clamp(1.05rem, 2vw, 1.3rem);
    line-height: 1.45;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 1.4rem;
  }

  .hero-cta-wrap {
    position: relative;
    display: inline-flex;
    width: fit-content;
  }

  .hero-cta-tip {
    position: absolute;
    bottom: calc(100% + 0.8rem);
    left: 50%;
    z-index: 4;
    display: flex;
    align-items: center;
    gap: 0.68rem;
    width: min(19rem, calc(100vw - 2rem));
    padding: 0.72rem 0.82rem 0.72rem 0.72rem;
    border: 1px solid rgba(184, 168, 255, 0.46);
    border-radius: 20px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.075), transparent),
      rgba(16, 12, 30, 0.96);
    color: var(--ink);
    font-size: 0.88rem;
    font-weight: 760;
    line-height: 1.22;
    letter-spacing: -0.02em;
    opacity: 0;
    pointer-events: none;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.14),
      0 22px 54px rgba(17, 9, 46, 0.5);
    transform: translate(-50%, 0.45rem) scale(0.98);
    transition:
      opacity 180ms ease,
      transform 180ms ease;
  }

  .hero-cta-tip::after {
    content: "";
    position: absolute;
    left: 50%;
    bottom: -0.42rem;
    width: 0.8rem;
    height: 0.8rem;
    border-right: 1px solid rgba(184, 168, 255, 0.46);
    border-bottom: 1px solid rgba(184, 168, 255, 0.46);
    background: rgba(16, 12, 30, 0.96);
    transform: translateX(-50%) rotate(45deg);
  }

  .hero-cta-wrap:hover .hero-cta-tip,
  .hero-cta-wrap:focus-within .hero-cta-tip {
    opacity: 1;
    transform: translate(-50%, 0) scale(1);
  }

  .whatsapp-mark {
    display: inline-grid;
    flex: 0 0 auto;
    place-items: center;
    width: 2.15rem;
    height: 2.15rem;
    border-radius: 50%;
    background: #25d366;
    box-shadow: 0 10px 24px rgba(37, 211, 102, 0.25);
  }

  .whatsapp-mark img {
    width: 1.15rem;
    height: 1.15rem;
  }

  .hero-stage {
    position: relative;
    min-height: min(560px, 68vh);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background:
      radial-gradient(
        circle at 40% 20%,
        rgba(116, 82, 255, 0.45),
        transparent 18rem
      ),
      linear-gradient(
        145deg,
        rgba(255, 255, 255, 0.12),
        rgba(255, 255, 255, 0.02)
      );
    overflow: hidden;
  }

  .hero-stage::before {
    content: "TikTok Affiliate Partner";
    position: absolute;
    right: -3rem;
    bottom: 2.2rem;
    color: rgba(255, 255, 255, 0.08);
    font-size: clamp(2.4rem, 7vw, 7rem);
    font-weight: 900;
    letter-spacing: -0.08em;
    line-height: 0.85;
    text-transform: uppercase;
  }

  .phone-card {
    position: absolute;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.22);
    border-radius: 32px;
    background: var(--surface);
    box-shadow: 0 32px 90px rgba(0, 0, 0, 0.45);
  }

  .phone-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .phone-card-main {
    top: 8%;
    left: 10%;
    width: 46%;
    height: 72%;
    transform: rotate(-5deg);
  }

  .phone-card-offset {
    right: 8%;
    bottom: 9%;
    width: 42%;
    height: 52%;
    transform: rotate(6deg);
  }

  .hero-orbit {
    position: absolute;
    right: 16%;
    top: 12%;
    display: grid;
    place-items: center;
    width: 9rem;
    height: 9rem;
    border: 1px solid rgba(255, 255, 255, 0.22);
    border-radius: 50%;
    background: rgba(8, 7, 11, 0.82);
  }

  .hero-orbit img {
    width: 58%;
  }

  .intro {
    padding-top: 0;
    scroll-margin-top: 6rem;
  }

  .intro blockquote {
    position: relative;
    margin: 0;
    padding: clamp(2rem, 5vw, 4.4rem) 0 clamp(1.6rem, 4vw, 3rem);
    border-top: 1px solid rgba(249, 242, 217, 0.2);
    border-bottom: 1px solid rgba(249, 242, 217, 0.14);
  }

  .intro-quote-mark {
    position: absolute;
    top: clamp(0.35rem, 1.5vw, 1.1rem);
    left: -0.08em;
    color: rgba(248, 241, 215, 0.22);
    font-size: clamp(5.5rem, 12vw, 12rem);
    font-weight: 900;
    line-height: 0.8;
    letter-spacing: -0.1em;
  }

  .intro-quote-copy {
    position: relative;
    max-width: 1080px;
    margin: 0;
    color: var(--ink);
    font-weight: 900;
    text-wrap: balance;
  }

  .quote-line {
    display: block;
    will-change: transform, opacity;
  }

  .quote-context {
    display: flex;
    flex-wrap: wrap;
    gap: 0 0.28em;
    color: rgba(247, 245, 255, 0.42);
    font-size: clamp(1.1rem, 1.9vw, 1.75rem);
    font-weight: 750;
    line-height: 1.05;
    letter-spacing: -0.04em;
  }

  .quote-capability {
    margin-top: clamp(1rem, 2vw, 1.6rem);
    color: rgba(247, 245, 255, 0.55);
    font-size: clamp(1.45rem, 2.5vw, 2.5rem);
    font-weight: 740;
    line-height: 1;
    letter-spacing: -0.055em;
  }

  .quote-capability strong {
    display: block;
    color: var(--accent-2);
    font-size: clamp(4.4rem, 10vw, 10.2rem);
    font-weight: 950;
    line-height: 0.78;
    letter-spacing: -0.115em;
    text-shadow: 0 20px 90px rgba(116, 82, 255, 0.34);
    will-change: transform, opacity;
  }

  .quote-outcome {
    margin-top: clamp(2rem, 4.5vw, 3.8rem);
  }

  .quote-outcome-lead {
    display: block;
    color: rgba(247, 245, 255, 0.46);
    font-size: clamp(1.35rem, 2.5vw, 2.5rem);
    font-weight: 740;
    line-height: 1;
    letter-spacing: -0.055em;
  }

  .quote-value {
    display: block;
    max-width: 1060px;
    color: var(--ink);
    font-size: clamp(3rem, 6.6vw, 6.8rem);
    font-weight: 900;
    line-height: 0.88;
    letter-spacing: -0.095em;
  }

  .quote-method {
    margin-top: clamp(1.15rem, 2.2vw, 1.8rem);
    color: rgba(247, 245, 255, 0.38);
    font-size: clamp(1.25rem, 2.3vw, 2.2rem);
    font-weight: 700;
    line-height: 1.02;
    letter-spacing: -0.05em;
  }

  .quote-method strong {
    color: rgba(184, 168, 255, 0.78);
    font-weight: 850;
  }

  .intro footer {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: clamp(1.5rem, 4vw, 2.6rem);
    color: var(--muted);
  }

  .intro footer::before {
    content: "";
    width: clamp(2.8rem, 7vw, 5.2rem);
    height: 2px;
    border-radius: 999px;
    background: #f8f1d7;
    opacity: 0.78;
  }

  .intro footer strong {
    color: var(--ink);
    font-size: clamp(1rem, 2vw, 1.28rem);
    font-weight: 900;
    letter-spacing: -0.04em;
  }

  .intro footer span {
    color: rgba(247, 245, 255, 0.48);
    font-size: 0.88rem;
    font-weight: 850;
    letter-spacing: -0.01em;
  }

  .section-title {
    max-width: 780px;
    margin-bottom: clamp(2rem, 5vw, 3.5rem);
  }

  .section-title h2 {
    margin: 0;
    font-size: clamp(2.6rem, 6vw, 5.8rem);
    line-height: 0.92;
    letter-spacing: -0.075em;
  }

  .section-title p:not(.va-kicker) {
    max-width: 42rem;
    margin-top: 1rem;
    color: var(--muted);
    font-size: 1.06rem;
    line-height: 1.6;
  }

  .section-title-compact {
    margin-bottom: 0;
  }

  .viral-reel-wall {
    display: grid;
    gap: 1rem;
  }

  .viral-row {
    display: grid;
    grid-template-columns: 220px minmax(0, 1fr);
    align-items: center;
    gap: 1rem;
    min-height: 260px;
    padding: 1rem;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background:
      linear-gradient(90deg, rgba(116, 82, 255, 0.12), transparent 55%),
      rgba(255, 255, 255, 0.045);
    overflow: hidden;
  }

  .viral-row-copy h3,
  .service-card h3 {
    margin: 0;
    font-size: clamp(1.9rem, 4vw, 3.5rem);
    line-height: 0.95;
    letter-spacing: -0.06em;
  }

  .viral-row-copy p,
  .service-card p,
  .result-card p,
  .account-card p {
    color: var(--muted);
    line-height: 1.55;
  }

  .viral-carousel {
    position: relative;
    overflow: hidden;
    min-width: 0;
    padding-block: 0.35rem;
    mask-image: linear-gradient(
      90deg,
      transparent,
      black 7%,
      black 93%,
      transparent
    );
  }

  .viral-track {
    display: flex;
    width: max-content;
    gap: 0.8rem;
    animation: viral-scroll 44s linear infinite;
  }

  .viral-carousel[data-direction="right"] .viral-track {
    animation-direction: reverse;
  }

  .viral-carousel:hover .viral-track {
    animation-play-state: paused;
  }

  .viral-card {
    position: relative;
    flex: 0 0 170px;
    width: 170px;
    margin: 0;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 22px;
    background: #050408;
  }

  .viral-card img {
    display: block;
    width: 100%;
    aspect-ratio: 3 / 4;
    object-fit: contain;
  }

  .viral-card figcaption {
    position: absolute;
    left: 0.55rem;
    bottom: 0.5rem;
    display: inline-flex;
    align-items: baseline;
    gap: 0.3rem;
    padding: 0.3rem 0.46rem;
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 999px;
    background: rgba(0, 0, 0, 0.58);
    color: white;
    font-weight: 900;
    letter-spacing: -0.03em;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  .viral-card figcaption small {
    color: rgba(255, 255, 255, 0.68);
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0;
  }

  .video-strip {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 1rem;
  }

  .video-strip a {
    display: grid;
    gap: 0.75rem;
    overflow: hidden;
    padding: 0.65rem;
    border: 1px solid var(--line);
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.06);
    text-decoration: none;
  }

  .video-strip a:hover {
    transform: translateY(-4px);
    border-color: rgba(116, 82, 255, 0.8);
  }

  .video-strip img {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border-radius: 16px;
  }

  .video-strip span {
    color: var(--accent-2);
    font-size: 0.82rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .video-strip strong {
    color: var(--ink);
    font-size: clamp(1rem, 1.6vw, 1.18rem);
    font-weight: 900;
    line-height: 0.98;
    letter-spacing: -0.05em;
  }

  .accounts {
    display: grid;
    grid-template-columns: 0.95fr 1.05fr;
    align-items: end;
    gap: clamp(2rem, 5vw, 4rem);
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }

  .account-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.8rem;
  }

  .account-card {
    min-height: 230px;
    padding: 1rem;
    border: 1px solid var(--line);
    border-radius: 26px;
    background: rgba(255, 255, 255, 0.06);
    text-decoration: none;
  }

  .account-card:hover {
    transform: translateY(-4px);
    border-color: rgba(116, 82, 255, 0.75);
  }

  .account-card img {
    width: 76px;
    height: 76px;
    margin-bottom: 1rem;
    border-radius: 50%;
    object-fit: cover;
    background: white;
  }

  .account-card span {
    display: block;
    font-size: 1.4rem;
    font-weight: 850;
    letter-spacing: -0.05em;
  }

  .service-grid {
    display: grid;
    grid-template-columns: repeat(6, minmax(0, 1fr));
    gap: 1rem;
  }

  .service-card {
    display: grid;
    grid-column: span 3;
    min-height: 460px;
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--surface);
  }

  .service-card-3,
  .service-card-4,
  .service-card-5 {
    grid-column: span 2;
  }

