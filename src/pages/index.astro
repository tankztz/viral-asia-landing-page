    }

    .quote-outcome {
      margin-top: 2rem;
    }

    .quote-outcome-lead {
      font-size: clamp(1.2rem, 5.8vw, 1.65rem);
    }

    .quote-value {
      font-size: clamp(2.55rem, 12.7vw, 3.8rem);
      line-height: 0.9;
      letter-spacing: -0.095em;
    }

    .quote-method {
      margin-top: 1.2rem;
      font-size: clamp(1.1rem, 5.3vw, 1.5rem);
      line-height: 1.06;
