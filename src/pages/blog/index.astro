---
import type { SanityDocument } from "@sanity/client";
import { sanityClient } from "sanity:client";
import Layout from "../../layouts/Layout.astro";
import { navItems, viralPostItems, whatsappHref } from "../../data/viralSite";

interface BlogPost extends SanityDocument {
  title: string;
  slug: { current: string };
  publishedAt?: string;
  excerpt?: string;
  author?: { name?: string };
  categories?: { title?: string }[];
  mainImage?: {
    asset?: {
      url?: string;
    };
  };
}

interface BlogCategory extends SanityDocument {
  title: string;
  description?: string;
}

const POSTS_QUERY = `*[
  _type == "post"
  && defined(slug.current)
]|order(publishedAt desc)[0...18]{
  _id,
  title,
  slug,
  publishedAt,
  excerpt,
  author->{name},
  categories[]->{title},
  mainImage {
    asset-> {
      url
    }
  }
}`;

const CATEGORIES_QUERY = `*[
  _type == "category"
  && defined(title)
]|order(title asc){
  _id,
  title,
  description
}`;

const [posts, studioCategories] = await Promise.all([
  sanityClient.fetch<BlogPost[]>(POSTS_QUERY),
  sanityClient.fetch<BlogCategory[]>(CATEGORIES_QUERY),
]);

const toFilterValue = (category: string) =>
  category
    .trim()
    .toLowerCase()
    .replace(/&/g, "and")
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-|-$/g, "");

const preferredCategoryOrder = [
  "SG Daily Happenings",
  "SG Food",
  "SG Events",
  "SG Explore",
  "TH Daily Happenings",
  "TH Food",
  "TH Events",
  "TH Explore",
];

const sortedCategoryTitles = studioCategories
  .map((category) => category.title?.trim())
  .filter((title): title is string => Boolean(title))
  .sort((a, b) => {
    const aIndex = preferredCategoryOrder.indexOf(a);
    const bIndex = preferredCategoryOrder.indexOf(b);
    if (aIndex !== -1 || bIndex !== -1) {
      return (aIndex === -1 ? Number.MAX_SAFE_INTEGER : aIndex) -
        (bIndex === -1 ? Number.MAX_SAFE_INTEGER : bIndex);
    }
    return a.localeCompare(b);
  });

const categoryNav = ["Latest", ...sortedCategoryTitles];

const topicHighlights = studioCategories
  .filter((category) => category.title?.trim() && category.description?.trim())
  .map((category) => [
    category.title.trim(),
    category.description!.trim(),
  ] as const);

const categoryTitleByFilter = new Map(
  studioCategories
    .map((category) => category.title?.trim())
    .filter((title): title is string => Boolean(title))
    .map((title) => [toFilterValue(title), title]),
);

const getStudioCategory = (title: string) =>
  categoryTitleByFilter.get(toFilterValue(title));

const resolveCategory = (fallback: string, alternatives: string[] = []) => {
  for (const title of [fallback, ...alternatives]) {
    const studioTitle = getStudioCategory(title);
    if (studioTitle) return studioTitle;
  }
  return fallback;
};

const formatDate = (date?: string) =>
  date
    ? new Date(date).toLocaleDateString("en-SG", {
        year: "numeric",
        month: "short",
        day: "numeric",
      })
    : "Viral Asia";

const inferCategory = (post: BlogPost) => {
  const explicitCategory = post.categories?.find((category) => category.title)
    ?.title?.trim();
  if (explicitCategory) {
    const studioCategory = getStudioCategory(explicitCategory);
    if (studioCategory) return studioCategory;
  }

  const title = post.title.toLowerCase();
  if (title.includes("lok lok") || title.includes("cafe") || title.includes("pork")) {
    return resolveCategory("Food", ["SG Food"]);
  }
  if (title.includes("jb") || title.includes("johor") || title.includes("batam") || title.includes("travel")) {
    return resolveCategory("Travel", ["SG Explore"]);
  }
  if (title.includes("festival") || title.includes("event") || title.includes("pop-up") || title.includes("opening")) {
    return resolveCategory("Events", ["SG Events"]);
  }
  if (title.includes("club") || title.includes("show") || title.includes("nightlife")) {
    return resolveCategory("Entertainment");
  }
  if (title.includes("deal") || title.includes("promo") || title.includes("discount") || title.includes("sale")) {
    return resolveCategory("Deals");
  }
  if (title.includes("beauty") || title.includes("fitness") || title.includes("wellness") || title.includes("health")) {
    return resolveCategory("Wellness");
  }
  if (title.includes("home") || title.includes("property")) {
    return resolveCategory("Property", ["SG Explore", "SG Daily Happenings"]);
  }
  if (title.includes("testing")) return "Studio";
  if (explicitCategory) {
    return resolveCategory(explicitCategory, ["SG Daily Happenings"]);
  }
  return resolveCategory("Lifestyle", ["SG Daily Happenings"]);
};

const inferCampaignCategory = (post: (typeof viralPostItems)[number]) => {
  const title = post.title.toLowerCase();
  if (title.includes("fishball") || title.includes("lok lok") || title.includes("cuisine") || title.includes("cafe")) {
    return resolveCategory("Food", ["SG Food"]);
  }
  if (title.includes("sentosa")) {
    return resolveCategory("Travel", ["SG Explore"]);
  }
  if (post.category === "news") {
    return resolveCategory("Happenings", ["SG Daily Happenings"]);
  }
  return resolveCategory("Brand Stories", ["SG Daily Happenings"]);
};

const getImage = (post?: BlogPost, width = 1200) =>
  post?.mainImage?.asset?.url
    ? `${post.mainImage.asset.url}?w=${width}&auto=format`
    : undefined;

const cleanPosts = posts.filter(
  (post) => post.slug?.current && post.title && !/test/i.test(post.title),
);
const featuredPost =
  cleanPosts.find((post) => !/test/i.test(post.title)) ?? cleanPosts[0];
const storyPosts = cleanPosts.filter((post) => post._id !== featuredPost?._id);
const topPosts = storyPosts.slice(0, 3);
const latestPosts =
  storyPosts.length > 3 ? storyPosts.slice(3, 11) : storyPosts;
const sidePosts =
  storyPosts.length > 8 ? storyPosts.slice(8, 12) : storyPosts.slice(0, 4);
const campaignPosts = viralPostItems.slice(0, 6);
const fallbackImages = campaignPosts.map((post) => post.cover);

const postHref = (post: BlogPost) => `/blog/${post.slug.current}`;
const postImage = (post?: BlogPost, width = 1200, fallbackIndex = 0) =>
  getImage(post, width) || fallbackImages[fallbackIndex % fallbackImages.length];

const defaultHero = {
  eyebrow: "SG Daily Happenings",
  title: "Latest happenings in Singapore",
};
const defaultCta = {
  eyebrow: "build viral stories and craft effective campaigns",
  title: "build viral stories and craft effective campaigns",
  button: "plan a campaign",
};

const blogSchema = {
  "@context": "https://schema.org",
  "@type": "Blog",
  name: "Latest happenings in Singapore",
  url: "/blog",
  publisher: {
    "@type": "Organization",
    name: "Viral Asia",
    logo: "/company/ViralAsia.png",
  },
  blogPost: cleanPosts.slice(0, 10).map((post) => ({
    "@type": "BlogPosting",
    headline: post.title,
    datePublished: post.publishedAt,
    url: postHref(post),
    articleSection: inferCategory(post),
    image: getImage(post),
  })),
};
---

<Layout title="Latest happenings in Singapore | Viral Asia">
  <script type="application/ld+json" set:html={JSON.stringify(blogSchema)} />

  <main class="blog-page" data-emdash-site="viral-asia" data-emdash-collection="posts">
    <div class="sticky-top" data-sticky-header>
      <div class="topbar">
        <button
          class="menu-toggle"
          type="button"
          aria-controls="blog-menu"
          aria-expanded="false"
          data-menu-toggle
        >
          <span class="menu-icon" aria-hidden="true">
            <span></span>
            <span></span>
            <span></span>
          </span>
          <span>Menu</span>
        </button>

        <a class="brand" href="/" aria-label="Viral Asia home">
          <img src="/images/viral-asia-logo-transparent.png" alt="Viral Asia" />
        </a>

        <a class="header-cta" href={whatsappHref}>Enquire now</a>
      </div>

      <nav class="site-nav" id="blog-menu" aria-label="Primary navigation" data-menu-panel hidden>
        <div>
          {navItems.map(([label, href]) => <a href={href}>{label}</a>)}
          <a href={whatsappHref}>Contact</a>
        </div>
      </nav>

      <nav class="category-strip" aria-label="Filter categories" data-category-filter>
        <div>
          {categoryNav.map((category, index) => (
            <button
              type="button"
              data-filter={toFilterValue(category)}
              aria-pressed={index === 0 ? "true" : "false"}
            >
              {category}
            </button>
          ))}
        </div>
      </nav>
    </div>

    <header class="news-header">
      <div class="masthead">
        <p data-hero-eyebrow>{defaultHero.eyebrow}</p>
        <h1 data-hero-title>{defaultHero.title}</h1>
      </div>
    </header>

    <section class="top-stories" aria-labelledby="top-stories-heading" data-filter-section>
      <div class="section-label">
        <h2 id="top-stories-heading">Top Stories</h2>
      </div>

      <div class="top-grid">
        {
          featuredPost && (
            <article
              class="lead-story"
              data-filter-card
              data-category={toFilterValue(inferCategory(featuredPost))}
              data-emdash-featured-post
            >
              <a href={postHref(featuredPost)}>
                <img src={postImage(featuredPost, 1400, 0)} alt={featuredPost.title} loading="eager" />
                <div>
                  <span>{inferCategory(featuredPost)}</span>
                  <h3>{featuredPost.title}</h3>
                  <p>
                    {featuredPost.excerpt ||
                      "Read the latest Viral Asia story shaped for fast, visual, Singapore-first audiences."}
                  </p>
                  <time>{formatDate(featuredPost.publishedAt)}</time>
                </div>
              </a>
            </article>
          )
        }

        <div class="side-stack" data-emdash-entry-list>
          {
            topPosts.map((post, index) => (
              <article
                class="compact-story"
                data-filter-card
                data-category={toFilterValue(inferCategory(post))}
                data-emdash-entry
              >
                <a href={postHref(post)}>
                  <img src={postImage(post, 700, index + 1)} alt={post.title} loading="lazy" />
                  <div>
                    <span>{inferCategory(post)}</span>
                    <h3>{post.title}</h3>
                    <time>{formatDate(post.publishedAt)}</time>
                  </div>
                </a>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="content-feed" aria-labelledby="latest-heading" data-filter-section data-primary-filter-section>
      <div class="main-feed">
        <div class="section-label">
          <h2 id="latest-heading">Latest Happenings</h2>
        </div>

        <div class="article-list" data-emdash-entry-list>
          {
            latestPosts.map((post, index) => (
              <article
                class="list-story"
                data-filter-card
                data-primary-filter-card
                data-category={toFilterValue(inferCategory(post))}
                data-emdash-entry
              >
                <a href={postHref(post)}>
                  <img src={postImage(post, 760, index + 5)} alt={post.title} loading="lazy" />
                  <div>
                    <span>{inferCategory(post)}</span>
                    <h3>{post.title}</h3>
                    {post.excerpt && <p>{post.excerpt}</p>}
                    <div class="story-meta">
                      <time>{formatDate(post.publishedAt)}</time>
                      <strong>{post.author?.name || "Viral Asia"}</strong>
                    </div>
                  </div>
                </a>
              </article>
            ))
          }
        </div>
      </div>

      <aside class="rail-feed" aria-label="More reads">
        <div class="rail-panel">
          <h2>Brand Features</h2>
          {
            campaignPosts.slice(0, 4).map((post) => (
              <a
                class="trend-row"
                href={`/redirect/${post.slug}/`}
                data-filter-card
                data-category={toFilterValue(inferCampaignCategory(post))}
              >
                <img src={post.cover} alt={post.title} loading="lazy" />
                <div>
                  <span>{post.category === "news" ? "Happenings signal" : "Brand story"}</span>
                  <strong>{post.title}</strong>
                  <p>{post.combinedViewsLabel} estimated cross-platform views</p>
                </div>
              </a>
            ))
          }
        </div>

        <div class="rail-panel">
          <h2>More Reads</h2>
          {
            sidePosts.length > 0 ? (
              sidePosts.map((post) => (
                <a class="text-row" href={postHref(post)}>
                  <span>{inferCategory(post)}</span>
                  <strong>{post.title}</strong>
                  <time>{formatDate(post.publishedAt)}</time>
                </a>
              ))
            ) : (
              <p class="empty-copy">More Sanity posts will appear here once they are published.</p>
            )
          }
        </div>
      </aside>
    </section>

    {
      topicHighlights.length > 0 && (
        <section class="topic-band" aria-label="Editorial categories" data-filter-section>
          {topicHighlights.map(([category, description]) => (
            <div data-filter-card data-category={toFilterValue(category)}>
              <span>{category}</span>
              <h2>{description}</h2>
            </div>
          ))}
        </section>
      )
    }

    <section class="blog-cta">
      <div>
        <p data-cta-eyebrow>{defaultCta.eyebrow}</p>
        <h2 data-cta-title>{defaultCta.title}</h2>
      </div>
      <a href={whatsappHref} data-cta-button>{defaultCta.button}</a>
    </section>

    <p class="filter-empty" data-filter-empty>More stories in this category will appear here once they are published.</p>

    <script is:inline>
      (() => {
        const initMenu = () => {
          const header = document.querySelector("[data-sticky-header]");
          const toggle = document.querySelector("[data-menu-toggle]");
          const panel = document.querySelector("[data-menu-panel]");
          if (!header || !toggle || !panel) return;

          const setMenuState = (isOpen) => {
            toggle.setAttribute("aria-expanded", String(isOpen));
            panel.hidden = !isOpen;
            header.toggleAttribute("data-menu-open", isOpen);
          };

          toggle.addEventListener("click", () => {
            setMenuState(toggle.getAttribute("aria-expanded") !== "true");
          });

          panel.addEventListener("click", (event) => {
            if (event.target.closest("a")) setMenuState(false);
          });

          document.addEventListener("keydown", (event) => {
            if (event.key === "Escape") setMenuState(false);
          });

          document.addEventListener("click", (event) => {
            if (!header.contains(event.target)) setMenuState(false);
          });
        };

        const initCategoryFilters = () => {
          const filterRoot = document.querySelector("[data-category-filter]");
          const filterButtons = Array.from(
            document.querySelectorAll("[data-category-filter] button[data-filter]"),
          );
          const filterCards = Array.from(
            document.querySelectorAll("[data-filter-card][data-category]"),
          );
          const emptyMessage = document.querySelector("[data-filter-empty]");
          const heroEyebrow = document.querySelector("[data-hero-eyebrow]");
          const heroTitle = document.querySelector("[data-hero-title]");
          const ctaEyebrow = document.querySelector("[data-cta-eyebrow]");
          const ctaTitle = document.querySelector("[data-cta-title]");
          const ctaButton = document.querySelector("[data-cta-button]");
          const filterSections = Array.from(
            document.querySelectorAll("[data-filter-section]"),
          );

          const getCountryLabel = (filter) => {
            const countryCode = (filter || "").split("-")[0];
            const countries = { sg: "Singapore", th: "Thailand" };
            return countries[countryCode] || countryCode.toLowerCase();
          };

          const getHappeningsEyebrow = (filter) => {
            const countryCode = (filter || "").split("-")[0].toUpperCase();
            return `${countryCode} Daily Happenings`;
          };

          const updatePageCopy = (filter) => {
            const isHappenings = filter.includes("happenings");
            if (isHappenings) {
              if (heroEyebrow) heroEyebrow.textContent = getHappeningsEyebrow(filter);
              if (heroTitle) heroTitle.textContent = `Latest happenings in ${getCountryLabel(filter)}`;
              if (ctaEyebrow) ctaEyebrow.textContent = "have a story to share?";
              if (ctaTitle) ctaTitle.textContent = "write in to us @ hello@viralasia.co or whatsapp us at 90906912";
              if (ctaButton) ctaButton.textContent = "share a story";
            } else {
              if (heroEyebrow) heroEyebrow.textContent = "SG Daily Happenings";
              if (heroTitle) heroTitle.textContent = "Latest happenings in Singapore";
              if (ctaEyebrow) ctaEyebrow.textContent = "build viral stories and craft effective campaigns";
              if (ctaTitle) ctaTitle.textContent = "build viral stories and craft effective campaigns";
              if (ctaButton) ctaButton.textContent = "plan a campaign";
            }
          };

          const applyCategoryFilter = (filter, shouldPush = true) => {
            const normalizedFilter = filter || "latest";
            let activeButton = null;
            let visibleCount = 0;

            updatePageCopy(normalizedFilter);

            filterButtons.forEach((button) => {
              const isActive = button.dataset.filter === normalizedFilter;
              button.setAttribute(
                "aria-pressed",
                String(isActive),
              );
              if (isActive) activeButton = button;
            });

            filterCards.forEach((card) => {
              const category = card.dataset.category || "";
              const shouldShow = normalizedFilter === "latest" || category === normalizedFilter;
              card.hidden = !shouldShow;
              if (shouldShow) visibleCount += 1;
            });

            filterSections.forEach((section) => {
              const sectionCards = Array.from(
                section.hasAttribute("data-primary-filter-section")
                  ? section.querySelectorAll("[data-primary-filter-card][data-category]")
                  : section.querySelectorAll("[data-filter-card][data-category]"),
              );
              const visibleSectionCards = sectionCards.filter((card) => !card.hidden);
              section.toggleAttribute(
                "data-filter-empty-section",
                normalizedFilter !== "latest" && visibleSectionCards.length === 0,
              );
            });

            emptyMessage?.setAttribute("data-visible", String(visibleCount === 0));
            activeButton?.scrollIntoView({ block: "nearest", inline: "center" });

            if (shouldPush) {
              const nextUrl = new URL(window.location.href);
              if (normalizedFilter === "latest") {
                nextUrl.searchParams.delete("category");
              } else {
                nextUrl.searchParams.set("category", normalizedFilter);
              }
              window.history.replaceState({}, "", nextUrl);
            }
          };

          filterRoot?.addEventListener("click", (event) => {
            const button = event.target.closest("button[data-filter]");
            if (!button) return;
            applyCategoryFilter(button.dataset.filter || "latest");
          });

          const initialFilter = new URL(window.location.href).searchParams.get("category");
          if (initialFilter) applyCategoryFilter(initialFilter, false);
        };

        if (document.readyState === "loading") {
          document.addEventListener(
            "DOMContentLoaded",
            () => {
              initMenu();
              initCategoryFilters();
            },
            { once: true },
          );
        } else {
          initMenu();
          initCategoryFilters();
        }
      })();
    </script>

    <footer class="news-footer">
      <div>
        <a href="/" aria-label="Viral Asia home">
          <img src="/images/viral-asia-logo-transparent.png" alt="Viral Asia" />
        </a>
      </div>

      <nav aria-label="Footer navigation">
        <a href="/work">Our Work</a>
        <a href="/services">Services</a>
        <a href="/about">About Us</a>
        <a href={whatsappHref}>Contact</a>
      </nav>
    </footer>
  </main>
</Layout>

<style>
  :global(body) {
    background: #ffffff;
  }

  .blog-page {
    --red: #ed1c24;
    --red-dark: #b80f16;
    --ink: #111111;
    --muted: #666666;
    --line: #dedede;
    --paper: #ffffff;
    --soft: #f5f5f5;
    min-height: 100dvh;
    overflow-x: clip;
    background: var(--paper);
    color: var(--ink);
    font-family: var(--font-body);
  }

  .news-header {
    border-bottom: 1px solid var(--line);
    background: var(--paper);
  }

  .sticky-top {
    position: sticky;
    top: 0;
    z-index: 40;
    border-bottom: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.96);
    backdrop-filter: blur(18px);
  }

  .topbar {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
    align-items: center;
    gap: 1rem;
    max-width: 1180px;
    margin: 0 auto;
    min-height: 4rem;
    padding: 0.7rem 1.25rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    justify-self: center;
    min-width: 0;
  }

  .brand img {
    display: block;
    width: 5.8rem;
    height: auto;
  }

  .menu-toggle,
  .site-nav a,
  .header-cta,
  .category-strip button,
  .section-label h2,
  .story-meta,
  .lead-story span,
  .compact-story span,
  .list-story span,
  .trend-row span,
  .text-row span,
  .topic-band span,
  .blog-cta p {
    font: 900 0.74rem/1 var(--font-body);
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .menu-toggle {
    display: inline-flex;
    align-items: center;
    justify-self: start;
    gap: 0.6rem;
    width: max-content;
    border: 0;
    background: transparent;
    color: var(--ink);
    cursor: pointer;
    padding: 0.5rem 0;
  }

  .menu-icon {
    display: grid;
    gap: 0.22rem;
    width: 1.4rem;
  }

  .menu-icon span {
    display: block;
    height: 2px;
    background: currentColor;
    transform-origin: center;
    transition:
      opacity 160ms ease,
      transform 160ms ease;
  }

  .sticky-top[data-menu-open] .menu-icon span:nth-child(1) {
    transform: translateY(0.38rem) rotate(45deg);
  }

  .sticky-top[data-menu-open] .menu-icon span:nth-child(2) {
    opacity: 0;
  }

  .sticky-top[data-menu-open] .menu-icon span:nth-child(3) {
    transform: translateY(-0.38rem) rotate(-45deg);
  }

  .site-nav {
    border-top: 1px solid var(--line);
    background: #ffffff;
  }

  .site-nav[hidden] {
    display: none;
  }

  .site-nav div {
    display: grid;
    grid-template-columns: repeat(7, minmax(0, 1fr));
    gap: 1px;
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 1.25rem 1px;
    background: var(--line);
  }

  .site-nav a {
    display: flex;
    align-items: center;
    min-height: 3.1rem;
    background: #ffffff;
    color: var(--ink);
    padding: 0.9rem 0.85rem;
    text-decoration: none;
    white-space: nowrap;
  }

  .site-nav a:hover {
    color: var(--red);
  }

  .header-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    justify-self: end;
    border-radius: 3px;
    background: var(--red);
    color: #ffffff;
    min-height: 2.4rem;
    padding: 0.72rem 0.95rem;
    text-decoration: none;
    white-space: nowrap;
  }

  .masthead {
    background: var(--red);
    color: #ffffff;
    padding: clamp(1.8rem, 4vw, 3.8rem) 1.25rem;
    text-align: center;
  }

  .masthead p {
    margin: 0 0 0.65rem;
    color: rgba(255, 255, 255, 0.84);
    font: 900 0.82rem/1 var(--font-body);
    letter-spacing: 0.05em;
    text-transform: none;
  }

  .masthead h1 {
    max-width: 960px;
    margin: 0 auto;
    font:
      900 clamp(2.8rem, 8vw, 7rem) / 0.88 var(--font-display);
    letter-spacing: 0;
