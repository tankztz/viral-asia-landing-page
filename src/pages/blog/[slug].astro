---
import type { SanityDocument } from "@sanity/client";
import { sanityClient } from "sanity:client";
import { PortableText } from "astro-portabletext";
import Layout from "../../layouts/Layout.astro";
import PortableSanityImage from "../../components/PortableSanityImage.astro";
import { navItems, viralPostItems, whatsappHref } from "../../data/viralSite";

interface BlogPost extends SanityDocument {
  title: string;
  slug: { current: string };
  publishedAt?: string;
  excerpt?: string;
  author?: { name?: string };
  categories?: { title?: string }[];
  mainImage?: {
    asset?: {
      url?: string;
    };
  };
  body?: unknown[];
  readingMinutes?: number;
}

export async function getStaticPaths(): Promise<{ params: { slug: string } }[]> {
  const SLUGS_QUERY = `*[_type == "post" && defined(slug.current)]{
    "params": {"slug": slug.current}
  }`;
  return await sanityClient.fetch(SLUGS_QUERY);
}

const POST_QUERY = `*[_type == "post" && slug.current == $slug][0]{
  _id,
  title,
  slug,
  publishedAt,
  excerpt,
  author->{name},
  categories[]->{title},
  mainImage {
    asset-> {
      url
    }
  },
  body,
  "readingMinutes": round(length(pt::text(body)) / 900)
}`;

const RELATED_POSTS_QUERY = `*[
  _type == "post"
  && defined(slug.current)
  && slug.current != $slug
  && !(_id in path("drafts.**"))
]|order(publishedAt desc)[0...6]{
  _id,
  title,
  slug,
  publishedAt,
  excerpt,
  author->{name},
  categories[]->{title},
  mainImage {
    asset-> {
      url
    }
  }
}`;

const post = await sanityClient.fetch<BlogPost>(POST_QUERY, Astro.params);
const relatedPosts = await sanityClient.fetch<BlogPost[]>(
  RELATED_POSTS_QUERY,
  Astro.params,
);

const formatDate = (date?: string) =>
  date
    ? new Date(date).toLocaleDateString("en-SG", {
        year: "numeric",
        month: "short",
        day: "numeric",
      })
    : "Viral Asia";

const inferCategory = (entry: BlogPost) => {
  const explicitCategory = entry.categories?.find((category) => category.title)
    ?.title;
  if (explicitCategory) return explicitCategory;

  const title = entry.title.toLowerCase();
  if (title.includes("lok lok") || title.includes("cafe") || title.includes("pork")) {
    return "Food";
  }
  if (title.includes("home") || title.includes("property")) return "Property";
  if (title.includes("testing")) return "Studio";
  return "Lifestyle";
};

const getImage = (entry?: BlogPost, width = 1400) =>
  entry?.mainImage?.asset?.url
    ? `${entry.mainImage.asset.url}?w=${width}&auto=format`
    : undefined;

const primaryCategory = post ? inferCategory(post) : "Story";
const isHappeningsArticle = primaryCategory.toLowerCase().includes("happenings");
const articleCta = isHappeningsArticle
  ? {
      eyebrow: "have a story to share?",
      title: "write in to us @ hello@viralasia.co or whatsapp us at 90906912",
      button: "share a story",
    }
  : {
      eyebrow: "build viral stories and craft effective campaigns",
      title: "build viral stories and craft effective campaigns",
      button: "plan a campaign",
    };
const heroImage = getImage(post);
const fallbackImage = viralPostItems[0]?.cover;
const readingMinutes = Math.max(post?.readingMinutes || 2, 2);
const articleDescription = post?.excerpt;
const schemaDescription = post?.excerpt || post?.title;
const canonicalUrl = post?.slug?.current
  ? `https://viralasia.co/blog/${post.slug.current}/`
  : undefined;
const cleanRelatedPosts = relatedPosts.filter(
  (entry) => entry.slug?.current && entry.title && !/test/i.test(entry.title),
);

const articleSchema = post && {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.title,
  description: schemaDescription,
  datePublished: post.publishedAt,
  author: {
    "@type": "Organization",
    name: post.author?.name || "Viral Asia",
  },
  publisher: {
    "@type": "Organization",
    name: "Viral Asia",
    logo: "/company/ViralAsia.png",
  },
  articleSection: primaryCategory,
  image: heroImage,
  mainEntityOfPage: canonicalUrl,
  url: canonicalUrl,
};

const portableTextComponents = {
  type: {
    image: PortableSanityImage,
  },
};
---

<Layout
  title={`${post.title} | Viral Asia Blog`}
  description={schemaDescription}
  canonicalUrl={canonicalUrl}
  imageUrl={heroImage}
  type="article"
>
  {articleSchema && <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />}

  <main class="article-page" data-emdash-site="viral-asia" data-emdash-entry={post.slug.current}>
    <div class="sticky-top" data-sticky-header>
      <div class="topbar">
        <button
          class="menu-toggle"
          type="button"
          aria-controls="blog-menu"
          aria-expanded="false"
          data-menu-toggle
        >
          <span class="menu-icon" aria-hidden="true">
            <span></span>
            <span></span>
            <span></span>
          </span>
          <span>Menu</span>
        </button>

        <a class="brand" href="/" aria-label="Viral Asia home">
          <img src="/images/viral-asia-logo-transparent.png" alt="Viral Asia" />
        </a>

        <a class="header-cta" href={whatsappHref}>Enquire now</a>
      </div>

      <nav class="site-nav" id="blog-menu" aria-label="Primary navigation" data-menu-panel hidden>
        <div>
          {navItems.map(([label, href]) => <a href={href}>{label}</a>)}
          <a href={whatsappHref}>Contact</a>
        </div>
      </nav>

      <nav class="article-strip" aria-label="Article navigation">
        <div>
          <a href="/blog">Back to Blog</a>
          <span>{primaryCategory}</span>
          <span>{formatDate(post.publishedAt)}</span>
        </div>
      </nav>
    </div>

    <article class="story-shell">
      <header class="article-hero">
        <div class="headline-block">
          <p>{primaryCategory}</p>
          <h1>{post.title}</h1>
          {articleDescription && <span>{articleDescription}</span>}
          <div class="article-meta">
            <strong>{post.author?.name || "Viral Asia editorial"}</strong>
            <time>{formatDate(post.publishedAt)}</time>
            <span>{readingMinutes} min read</span>
          </div>
        </div>

        <figure>
          <img
            src={heroImage || fallbackImage}
            alt={post.title}
            width="1400"
            height="900"
            loading="eager"
          />
        </figure>
      </header>

      <div class="article-layout">
        <aside class="article-rail" aria-label="Article details">
          <div>
            <span>Category</span>
            <strong>{primaryCategory}</strong>
          </div>
          <div>
            <span>Published</span>
            <strong>{formatDate(post.publishedAt)}</strong>
          </div>
          <a href={whatsappHref}>{articleCta.button}</a>
        </aside>

        <div class="article-body" data-emdash-body>
          {Array.isArray(post.body) && post.body.length > 0 ? (
            <PortableText value={post.body} components={portableTextComponents} />
          ) : (
            <>
              <p>This story is ready for publishing in Sanity, but the article body is currently empty.</p>
              <p>Add content blocks in the Studio and the static Cloudflare build will render them here.</p>
            </>
          )}
        </div>
      </div>
    </article>

    <section class="more-stories" aria-labelledby="more-stories-heading">
      <div class="section-label">
        <h2 id="more-stories-heading">More Stories</h2>
      </div>

      <div class="related-grid">
        {
          cleanRelatedPosts.map((entry) => (
            <article>
              <a href={`/blog/${entry.slug.current}`}>
                <img
                  src={getImage(entry, 800) || viralPostItems[1]?.cover}
                  alt={entry.title}
                  loading="lazy"
                />
                <div>
                  <span>{inferCategory(entry)}</span>
                  <h3>{entry.title}</h3>
                  <time>{formatDate(entry.publishedAt)}</time>
                </div>
              </a>
            </article>
          ))
        }
      </div>
    </section>

    <section class="blog-cta">
      <div>
        <p>{articleCta.eyebrow}</p>
        <h2>{articleCta.title}</h2>
      </div>
      <a href={whatsappHref}>{articleCta.button}</a>
    </section>

    <script is:inline>
      (() => {
        const initMenu = () => {
          const header = document.querySelector("[data-sticky-header]");
          const toggle = document.querySelector("[data-menu-toggle]");
          const panel = document.querySelector("[data-menu-panel]");
          if (!header || !toggle || !panel) return;

          const setMenuState = (isOpen) => {
            toggle.setAttribute("aria-expanded", String(isOpen));
            panel.hidden = !isOpen;
            header.toggleAttribute("data-menu-open", isOpen);
          };

          toggle.addEventListener("click", () => {
            setMenuState(toggle.getAttribute("aria-expanded") !== "true");
          });

          panel.addEventListener("click", (event) => {
            if (event.target.closest("a")) setMenuState(false);
          });

          document.addEventListener("keydown", (event) => {
            if (event.key === "Escape") setMenuState(false);
          });

          document.addEventListener("click", (event) => {
            if (!header.contains(event.target)) setMenuState(false);
          });
        };

        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", initMenu, { once: true });
        } else {
          initMenu();
        }
      })();
    </script>

    <footer class="news-footer">
      <div>
        <a href="/" aria-label="Viral Asia home">
          <img src="/images/viral-asia-logo-transparent.png" alt="Viral Asia" />
        </a>
      </div>

      <nav aria-label="Blog footer navigation">
        <a href="/work">Our Work</a>
        <a href="/services">Services</a>
        <a href="/about">About Us</a>
        <a href={whatsappHref}>Contact</a>
      </nav>
    </footer>
  </main>
</Layout>

<style>
  :global(body) {
    background: #ffffff;
  }

  .article-page {
    --red: #ed1c24;
    --red-dark: #b80f16;
    --ink: #111111;
    --muted: #666666;
    --line: #dedede;
    --paper: #ffffff;
    --soft: #f5f5f5;
    min-height: 100dvh;
    overflow-x: clip;
    background: var(--paper);
    color: var(--ink);
    font-family: var(--font-body);
  }

  .sticky-top {
    position: sticky;
    top: 0;
    z-index: 40;
    border-bottom: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.96);
    backdrop-filter: blur(18px);
  }

  .topbar {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
    align-items: center;
    gap: 1rem;
    max-width: 1180px;
    margin: 0 auto;
    min-height: 4rem;
    padding: 0.7rem 1.25rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    justify-self: center;
    min-width: 0;
  }

  .brand img {
    display: block;
    width: 5.8rem;
    height: auto;
  }

  .menu-toggle,
  .site-nav a,
  .header-cta,
  .article-strip a,
  .article-strip span,
  .section-label h2,
  .article-meta,
  .headline-block p,
  .article-rail span,
  .article-rail a,
  .related-grid span,
  .blog-cta p {
    font: 900 0.74rem/1 var(--font-body);
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .menu-toggle {
    display: inline-flex;
    align-items: center;
    justify-self: start;
    gap: 0.6rem;
    width: max-content;
    border: 0;
    background: transparent;
    color: var(--ink);
    cursor: pointer;
    padding: 0.5rem 0;
  }

  .menu-icon {
    display: grid;
    gap: 0.22rem;
    width: 1.4rem;
  }

  .menu-icon span {
    display: block;
    height: 2px;
    background: currentColor;
    transform-origin: center;
    transition:
      opacity 160ms ease,
      transform 160ms ease;
  }

  .sticky-top[data-menu-open] .menu-icon span:nth-child(1) {
    transform: translateY(0.38rem) rotate(45deg);
  }

  .sticky-top[data-menu-open] .menu-icon span:nth-child(2) {
    opacity: 0;
  }

  .sticky-top[data-menu-open] .menu-icon span:nth-child(3) {
    transform: translateY(-0.38rem) rotate(-45deg);
  }

  .site-nav {
    border-top: 1px solid var(--line);
    background: #ffffff;
  }

  .site-nav[hidden] {
    display: none;
  }

  .site-nav div {
    display: grid;
    grid-template-columns: repeat(7, minmax(0, 1fr));
    gap: 1px;
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 1.25rem 1px;
    background: var(--line);
  }

  .site-nav a {
    display: flex;
    align-items: center;
    min-height: 3.1rem;
    background: #ffffff;
    color: var(--ink);
    padding: 0.9rem 0.85rem;
    text-decoration: none;
    white-space: nowrap;
  }

  .site-nav a:hover {
    color: var(--red);
  }

  .header-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    justify-self: end;
    border-radius: 3px;
    background: var(--red);
    color: #ffffff;
    min-height: 2.4rem;
    padding: 0.72rem 0.95rem;
    text-decoration: none;
    white-space: nowrap;
  }

  .article-strip {
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.96);
  }

  .article-strip div {
    display: flex;
    gap: 0.25rem;
    max-width: 1180px;
    margin: 0 auto;
    overflow-x: auto;
    padding: 0.75rem 1.25rem;
    scrollbar-width: none;
  }

  .article-strip div::-webkit-scrollbar {
    display: none;
  }

  .article-strip a,
  .article-strip span {
    flex: 0 0 auto;
    color: var(--ink);
    padding: 0.58rem 0.72rem;
    text-decoration: none;
    white-space: nowrap;
  }

  .article-strip a {
    background: var(--red);
    color: #ffffff;
  }

  .article-strip span {
    background: var(--soft);
  }

  .story-shell,
  .more-stories,
  .blog-cta {
    max-width: 1180px;
    margin: 0 auto;
    padding-right: 1.25rem;
    padding-left: 1.25rem;
  }

  .story-shell {
    padding-top: clamp(1.8rem, 4vw, 3.2rem);
    padding-bottom: clamp(2rem, 5vw, 4rem);
  }

  .article-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(300px, 1fr);
    gap: clamp(1.25rem, 4vw, 3rem);
    align-items: end;
  }

  .headline-block p {
    margin: 0 0 0.75rem;
    color: var(--red);
  }

  .headline-block h1 {
    margin: 0;
    max-width: 15ch;
    font: 900 clamp(2.5rem, 5.1vw, 4.9rem) / 0.94 var(--font-body);
    letter-spacing: -0.035em;
    text-wrap: balance;
  }

  .headline-block > span {
    display: block;
    max-width: 42rem;
    margin-top: 1rem;
    color: var(--muted);
    font: 600 1.06rem/1.55 var(--font-body);
  }

  .article-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-top: 1.2rem;
    color: #777777;
  }

  .article-meta strong {
    color: var(--ink);
  }

  .article-meta time::before,
  .article-meta span::before {
    margin-right: 0.6rem;
    color: var(--red);
    content: "/";
  }

  figure {
    margin: 0;
  }

  figure img {
    width: 100%;
    aspect-ratio: 16 / 10;
    background: var(--soft);
    object-fit: contain;
  }

  .article-layout {
    display: grid;
    grid-template-columns: 220px minmax(0, 760px);
    gap: clamp(1.4rem, 5vw, 4rem);
    align-items: start;
    margin-top: clamp(2.4rem, 6vw, 4.5rem);
  }

  .article-rail {
    position: sticky;
    top: 8rem;
    display: grid;
    gap: 0.85rem;
    border-top: 5px solid var(--red);
    color: var(--ink);
    padding-top: 1rem;
  }

  .article-rail div {
    border-bottom: 1px solid var(--line);
    padding-bottom: 0.85rem;
  }

  .article-rail span {
    display: block;
    margin-bottom: 0.35rem;
    color: var(--red);
  }

  .article-rail strong {
    font: 900 0.98rem/1.25 var(--font-body);
  }

  .article-rail a {
    display: inline-flex;
    justify-content: center;
    border-radius: 3px;
    background: var(--red);
    color: #ffffff;
    padding: 0.82rem 0.9rem;
    text-decoration: none;
    text-transform: none;
  }

  .article-body {
    color: var(--ink);
  }

  :global(.article-body p),
  :global(.article-body li) {
    color: #1d1d1d;
    font: 500 clamp(1.04rem, 2vw, 1.18rem) / 1.75 var(--font-body);
  }

  :global(.article-body p:first-child) {
    margin-top: 0;
  }

  :global(.article-body h2) {
    margin: 2.2rem 0 0.8rem;
    color: var(--ink);
    font: 900 clamp(1.8rem, 4.5vw, 3rem) / 0.98 var(--font-body);
    letter-spacing: -0.02em;
  }

  :global(.article-body h3) {
    margin: 1.8rem 0 0.7rem;
    color: var(--ink);
    font: 900 1.45rem/1.1 var(--font-body);
  }

  :global(.article-body blockquote) {
    margin: 2rem 0;
    border-left: 5px solid var(--red);
    color: var(--ink);
    font: 900 clamp(1.35rem, 3vw, 2rem) / 1.2 var(--font-body);
    padding-left: 1rem;
  }

  :global(.article-body img) {
    width: 100%;
    margin: 1.6rem 0;
  }

  :global(.article-body a) {
    color: var(--red-dark);
    font-weight: 900;
  }

  .more-stories {
    padding-bottom: clamp(2rem, 5vw, 4rem);
  }

  .section-label {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    margin-bottom: 1rem;
    border-bottom: 4px solid var(--red);
  }

  .section-label h2 {
    margin: 0;
    background: var(--red);
    color: #ffffff;
    padding: 0.62rem 0.82rem 0.58rem;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .related-grid a {
    display: grid;
    min-height: 100%;
    border: 1px solid var(--line);
    background: #ffffff;
    color: var(--ink);
    text-decoration: none;
  }

  .related-grid a:hover h3 {
    color: var(--red-dark);
  }

  .related-grid img {
    width: 100%;
    aspect-ratio: 4 / 3;
    background: var(--soft);
    object-fit: cover;
  }

  .related-grid div {
    display: grid;
    gap: 0.65rem;
    padding: 1rem;
  }

  .related-grid span {
    color: var(--red);
  }

  .related-grid h3 {
    margin: 0;
    font: 900 1.18rem/1.08 var(--font-body);
    text-wrap: pretty;
  }

  .related-grid time {
    color: #777777;
    font: 800 0.72rem/1 var(--font-body);
    text-transform: uppercase;
  }

  .blog-cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    border-top: 5px solid var(--red);
    padding-top: clamp(1.4rem, 3vw, 2rem);
    padding-bottom: clamp(2rem, 5vw, 4rem);
  }

  .blog-cta p {
    margin: 0 0 0.45rem;
    color: var(--red);
    text-transform: none;
  }

  .blog-cta h2 {
    max-width: 760px;
    margin: 0;
    font: 900 clamp(1.8rem, 4.2vw, 3.2rem) / 0.96 var(--font-body);
    letter-spacing: -0.02em;
    text-wrap: balance;
  }

  .blog-cta a {
    flex: 0 0 auto;
    border-radius: 3px;
    background: var(--red);
    color: #ffffff;
    font: 900 0.8rem/1 var(--font-body);
    padding: 0.9rem 1rem;
    text-decoration: none;
    text-transform: none;
    white-space: nowrap;
  }

  .news-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    border-top: 1px solid var(--line);
    background: var(--ink);
    color: #ffffff;
    padding: 1.3rem max(1.25rem, calc((100vw - 1180px) / 2 + 1.25rem));
  }

  .news-footer img {
    width: 7.2rem;
    height: auto;
    filter: brightness(0) invert(1);
  }

  .news-footer p {
    margin: 0.55rem 0 0;
    color: rgba(255, 255, 255, 0.72);
    font: 600 0.9rem/1.35 var(--font-body);
  }

  .news-footer nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.9rem;
  }

  .news-footer a {
    color: #ffffff;
    font: 900 0.72rem/1 var(--font-body);
    text-decoration: none;
    text-transform: uppercase;
  }

  .news-footer a:hover {
    color: var(--red);
  }

  @media (max-width: 980px) {
    .site-nav div {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .article-hero,
    .article-layout {
      grid-template-columns: 1fr;
    }

    .article-rail {
      position: static;
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .article-rail a {
      grid-column: 1 / -1;
      width: max-content;
    }

    .related-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 700px) {
    .topbar {
      gap: 0.8rem;
      grid-template-columns: minmax(4.5rem, 1fr) auto minmax(4.5rem, 1fr);
      min-height: 3.65rem;
      padding: 0.8rem 0.9rem;
    }

    .brand img {
      width: 5.1rem;
    }

    .header-cta {
      min-height: 2.15rem;
      padding: 0.6rem 0.75rem;
    }

    .menu-toggle > span:last-child {
      display: none;
    }

    .site-nav div {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      padding-right: 0.9rem;
      padding-left: 0.9rem;
    }

    .article-strip div,
    .story-shell,
    .more-stories,
    .blog-cta {
      padding-right: 0.9rem;
      padding-left: 0.9rem;
    }

    .headline-block h1 {
      max-width: 100%;
