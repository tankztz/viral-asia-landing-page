---
import Layout from "../layouts/Layout.astro";
import {
  allClientLogos,
  beforeAfter,
  navItems,
  operatedAccounts,
  pageContent,
  services,
  testimonials,
  whatsappHref,
} from "../data/viralSite";

export function getStaticPaths() {
  return Object.keys(pageContent).map((page) => ({
    params: { page },
    props: { content: pageContent[page as keyof typeof pageContent] },
  }));
}

const { content } = Astro.props;
---

<Layout title={`${content.title} - Viral Asia`}>
  <main class="subpage">
    <header class="topbar">
      <a class="brand" href="/" aria-label="Viral Asia home"
        ><span>Viral</span> Asia</a
      >
      <nav aria-label="Primary navigation">
        {navItems.map(([label, href]) => <a href={href}>{label}</a>)}
      </nav>
      <a class="cta" href={whatsappHref}>
        Get free consultation
        <img src="/icons/whatsapp.svg" alt="" aria-hidden="true" />
      </a>
    </header>

    <section class="page-hero">
      <p>Viral Asia</p>
      <h1>{content.title}</h1>
      <span>{content.intro}</span>
    </section>

    {
      content.title === "Services" && (
        <>
          <section class="before-after">
            <h2>Before and After</h2>
            <div>
              {beforeAfter.map((item) => (
                <article>
                  <img src={item.image} alt={item.partner} loading="lazy" />
                  <p>{item.quote}</p>
                  <strong>{item.partner}</strong>
                </article>
              ))}
            </div>
          </section>

          <section class="service-detail">
            <h2>What we offer</h2>
            <p>We offer a wide range of services to help your business grow.</p>
            <div>
              {services.map((service) => (
                <article>
                  <img src={service.image} alt={service.title} loading="lazy" />
                  <h3>{service.title}</h3>
                  <p>{service.body}</p>
                </article>
              ))}
            </div>
            <a class="cta service-cta" href={whatsappHref}>
              Contact us for surprising discount
              <img src="/icons/whatsapp.svg" alt="" aria-hidden="true" />
            </a>
          </section>
        </>
      )
    }

    {
      content.title === "Our work" && (
        <section class="account-grid">
          {operatedAccounts.map((account) => (
            <article>
              <div class="account-logo">
                <img
                  src={account.image}
                  alt={`${account.title} logo`}
                  loading="lazy"
                />
              </div>
              <span>{account.platform}</span>
              <h2>{account.title}</h2>
              <p>{account.handle}</p>
              <a
                class="article-link"
                href={account.href}
                target="_blank"
                rel="noopener noreferrer"
              >
                Open account
              </a>
            </article>
          ))}
        </section>
      )
    }

    {
      content.title === "Clients" && (
        <section class="client-logo-section">
          <div class="client-logo-grid">
            {allClientLogos.map(([image, name]) => (
              <div class="client-logo-card">
                <img src={`/logos/${image}`} alt={name} loading="lazy" />
              </div>
            ))}
          </div>
        </section>
      )
    }

    {
      !["Services", "Our work", "Clients"].includes(content.title) && (
        <section class="content-grid">
          {content.items.map(([title, body, meta]) => (
            <article>
              <h2>{title}</h2>
              <p>{body}</p>
              {meta &&
                (String(meta).startsWith("http") ||
                String(meta).startsWith("mailto:") ||
                String(meta).startsWith("tel:") ? (
                  <a class="article-link" href={meta}>
                    Open link
                  </a>
                ) : (
                  <strong>{meta}</strong>
                ))}
            </article>
          ))}
        </section>
      )
    }

    {
      content.title === "Clients" && (
        <section class="testimonial-grid">
          <h2>More testimonials</h2>
          <div>
            {testimonials.map((testimonial) => (
              <blockquote>
                <img
                  src={testimonial.logo}
                  alt={`${testimonial.name} brand logo`}
                  loading="lazy"
                />
                <p>{testimonial.quote}</p>
                <cite>
                  {testimonial.name}
                  <span>{testimonial.role}</span>
                </cite>
              </blockquote>
            ))}
          </div>
        </section>
      )
    }
  </main>
</Layout>

<style>
  :global(body) {
    background: #050505;
  }

  .subpage {
    --red: #e91515;
    --yellow: #ffe100;
    --line: rgba(255, 255, 255, 0.18);
    min-height: 100dvh;
    background:
      radial-gradient(
        circle at 50% 0,
        rgba(233, 21, 21, 0.22),
        transparent 28rem
      ),
      #050505;
    color: white;
    font-family:
      Impact, Haettenschweiler, "Arial Narrow Bold", "Arial Black", sans-serif;
    text-transform: uppercase;
  }

  .subpage p,
  .subpage span,
  .subpage a,
  .subpage cite {
    font-family: Arial, Helvetica, sans-serif;
    text-transform: none;
  }

  .topbar {
    display: grid;
    grid-template-columns: 180px 1fr auto;
    align-items: center;
    gap: 1rem;
    max-width: 1180px;
    margin: 0 auto;
    padding: 1rem 1.5rem;
  }

  .brand {
    color: white;
    font:
      900 1.9rem/0.9 Impact,
      Haettenschweiler,
      "Arial Narrow Bold",
      sans-serif;
    text-decoration: none;
  }

  .brand span,
  .page-hero p,
  .content-grid strong {
    color: var(--red);
  }

  nav {
    display: flex;
    justify-content: center;
    gap: clamp(0.9rem, 2.2vw, 2rem);
  }

  nav a {
    color: white;
    font-size: 0.72rem;
    font-weight: 900;
    text-decoration: none;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .cta {
    display: inline-flex;
    justify-content: center;
    min-height: 2.5rem;
    border-radius: 4px;
    background: var(--red);
    box-shadow: 0 0.45rem 0 rgba(0, 0, 0, 0.5);
    color: white;
    font-size: 0.82rem;
    font-weight: 900;
    padding: 0.65rem 1.2rem;
    text-decoration: none;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .cta img {
    width: 1rem;
    height: 1rem;
    margin-left: 0.5rem;
    filter: invert(1);
  }

  .page-hero {
    max-width: 1180px;
    margin: 0 auto;
    padding: clamp(3rem, 8vw, 7rem) 1.5rem 2rem;
  }

  .page-hero p {
    margin: 0 0 0.75rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p {
    margin: 0;
  }

  h1 {
    max-width: 9ch;
    font-size: clamp(4rem, 12vw, 9rem);
    line-height: 0.82;
  }

  .page-hero span {
    display: block;
    max-width: 46rem;
    margin-top: 1.2rem;
    color: #efefef;
    font-size: clamp(1.1rem, 2.4vw, 1.55rem);
    line-height: 1.2;
  }

  .content-grid,
  .account-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    max-width: 1180px;
    margin: 0 auto;
    padding: 1.5rem;
    border-top: 2px solid var(--red);
  }

  .content-grid article,
  .account-grid article,
  blockquote {
    min-height: 11rem;
    padding: 1.2rem;
    background: linear-gradient(135deg, #1b1b1b, #080808);
    border: 1px solid var(--line);
  }

  article h2 {
    font-size: clamp(1.7rem, 3vw, 2.6rem);
    line-height: 0.95;
  }

  article p {
    margin-top: 0.8rem;
    color: #e7e7e7;
    font-size: 0.98rem;
    line-height: 1.35;
  }

  article strong {
    display: block;
    margin-top: 1rem;
    font-size: 1.6rem;
  }

  .article-link {
    display: inline-flex;
    margin-top: 1rem;
    color: var(--yellow);
    font-size: 0.86rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  .account-grid {
    grid-template-columns: repeat(5, minmax(0, 1fr));
  }

  .account-grid article {
    display: grid;
  }

  .account-logo {
    display: grid;
    place-items: center;
    width: 4.4rem;
    height: 4.4rem;
    margin-bottom: 1rem;
    overflow: hidden;
    border-radius: 10px;
    background: #22145a;
  }

  .account-logo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .account-grid span {
    color: var(--yellow);
    font-size: 0.74rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  .before-after,
  .service-detail {
    max-width: 1180px;
    margin: 0 auto;
    padding: 1.5rem;
    border-top: 2px solid var(--red);
  }

  .before-after h2,
  .service-detail h2 {
    font-size: clamp(2.1rem, 4vw, 3.6rem);
    line-height: 0.95;
  }

  .before-after > div,
  .service-detail > div {
    display: grid;
    gap: 1rem;
    margin-top: 1rem;
  }

  .before-after > div {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .before-after article,
  .service-detail article {
    overflow: hidden;
    border: 1px solid var(--line);
    background: linear-gradient(135deg, #1b1b1b, #080808);
  }

  .before-after article {
    padding: 0;
  }

  .before-after img {
    width: 100%;
    height: 13rem;
    object-fit: cover;
    object-position: top;
  }

  .before-after p,
  .before-after strong {
    display: block;
    padding-inline: 1rem;
  }

  .before-after p {
    padding-top: 1rem;
    color: white;
    font-size: 0.98rem;
    font-weight: 900;
    line-height: 1.25;
  }

  .before-after strong {
    padding-block: 0.8rem 1rem;
    color: var(--yellow);
    font-size: 0.86rem;
  }

  .service-detail {
    background: #f4f4f4;
    color: #050505;
  }

  .service-detail > p {
    max-width: 38rem;
    margin-top: 0.5rem;
    color: #111;
    font-size: 1rem;
    line-height: 1.35;
  }

  .service-detail > div {
    grid-template-columns: repeat(5, minmax(0, 1fr));
  }

  .service-detail article {
    padding: 0.8rem;
    border: 2px solid #050505;
    background: white;
  }

  .service-detail article img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: 4px;
  }

  .service-detail h3 {
    margin-top: 0.7rem;
    font-size: 1.05rem;
    line-height: 0.95;
  }

  .service-detail article p {
    margin-top: 0.55rem;
    color: #111;
    font-size: 0.82rem;
    line-height: 1.3;
  }

  .service-cta {
    width: fit-content;
    margin-top: 1.25rem;
  }

  .client-logo-section {
    max-width: 1180px;
    margin: 0 auto;
    padding: 1.5rem;
    border-top: 2px solid var(--red);
  }

  .client-logo-grid {
    display: grid;
    grid-template-columns: repeat(8, minmax(0, 1fr));
    gap: 0.8rem;
  }

  .client-logo-card {
    display: grid;
    place-items: center;
    min-height: 5.6rem;
    padding: 0.75rem;
    border-radius: 6px;
    background: white;
  }

  .client-logo-card img {
    width: 100%;
    max-height: 3.7rem;
    object-fit: contain;
  }

  .testimonial-grid {
    max-width: 1180px;
    margin: 0 auto;
    padding: 1rem 1.5rem 3rem;
  }

  .testimonial-grid h2 {
    color: var(--yellow);
    font-size: clamp(2rem, 4vw, 3.4rem);
  }

  .testimonial-grid > div {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 1rem;
  }

  blockquote {
    margin: 0;
    border-left: 0.45rem solid var(--yellow);
  }

  blockquote p {
    color: white;
    font-size: 0.95rem;
    line-height: 1.35;
  }

  blockquote img {
    width: 3rem;
    height: 3rem;
    margin-bottom: 0.75rem;
    border-radius: 8px;
    object-fit: contain;
    background: white;
  }

  cite {
    display: block;
    margin-top: 0.9rem;
    color: white;
    font-size: 0.78rem;
    font-style: normal;
    font-weight: 800;
  }

  cite span {
    display: block;
    color: #c8c8c8;
  }

  @media (max-width: 880px) {
    .topbar,
    .content-grid,
    .account-grid,
    .testimonial-grid > div {
      grid-template-columns: 1fr;
    }

    nav {
      justify-content: flex-start;
      overflow-x: auto;
      gap: 0.65rem;
      scrollbar-width: none;
    }

    nav a {
      font-size: 0.66rem;
    }

    nav::-webkit-scrollbar {
      display: none;
    }

    .client-logo-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .before-after > div,
    .service-detail > div {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 520px) {
    .topbar {
      display: flex;
      flex-wrap: wrap;
    }

    .topbar nav {
      width: 100%;
    }

    .topbar .cta {
      width: 100%;
    }

    h1 {
      max-width: 100%;
      font-size: clamp(3.1rem, 16vw, 4.2rem);
    }

    .client-logo-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .before-after > div,
    .service-detail > div {
      grid-template-columns: 1fr;
    }

    .service-cta {
      width: 100%;
    }
  }
</style>
