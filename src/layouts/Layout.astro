---
import { isProduction, siteEnvironment } from "../config/environment";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="description"
      content="Viral Asia is a leading social media marketing company in Singapore that helps businesses grow their online presence"
    />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    {!isProduction && <meta name="robots" content="noindex, nofollow" />}
    <title>{title}</title>
  </head>
  <body>
    {
      !isProduction && (
        <aside class="staging-banner" role="status">
          Staging preview: {siteEnvironment}
        </aside>
      )
    }
    <slot />
  </body>
</html>
<style is:global>
  .staging-banner {
    position: sticky;
    top: 0;
    z-index: 100;
    padding: 0.5rem 1rem;
    background: #facc15;
    color: #18181b;
    font:
      700 0.75rem/1.25 system-ui,
      sans-serif;
    letter-spacing: 0.08em;
    text-align: center;
    text-transform: uppercase;
  }

  :root {
    color-scheme: dark;
    font-family:
      ui-sans-serif,
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      sans-serif;
    background: #08070b;
    color: #f7f5ff;
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  html {
    background: #08070b;
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    min-width: 320px;
    background: #08070b;
    color: #f7f5ff;
    text-rendering: optimizeLegibility;
    -webkit-font-smoothing: antialiased;
  }

  img {
    max-width: 100%;
    height: auto;
  }

  a {
    color: inherit;
  }
</style>
