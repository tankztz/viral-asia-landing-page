# Explicitly mark local or non-Cloudflare builds as staging.
# Cloudflare Pages previews are detected automatically from CF_PAGES_BRANCH.
PUBLIC_SITE_ENV=staging

# Sanity currently uses the production dataset for all builds.
# These values document the current content source for the future decoupling work.
PUBLIC_SANITY_PROJECT_ID=3an9f3n5
PUBLIC_SANITY_DATASET=production
